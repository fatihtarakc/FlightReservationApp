@model List<AdminBookingListItemViewModel>
@{
    ViewData["Title"] = "All Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-list-check me-2 text-primary"></i>All Bookings</h2>
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Dashboard
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox display-4"></i>
        <h5 class="mt-3">No bookings found.</h5>
    </div>
}
else
{
    var revenue = Model
        .Where(b => b.BookingStatus == BookingStatus.Confirmed || b.BookingStatus == BookingStatus.CheckedIn)
        .Sum(b => b.TotalPrice);

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <span class="fw-semibold">@Model.Count total bookings</span>
            <span class="text-muted small">Revenue: @revenue.ToString("N0") (Confirmed + CheckedIn)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th>PNR</th>
                            <th>Passenger</th>
                            <th>Flight</th>
                            <th>Route</th>
                            <th>Departure</th>
                            <th>Seat</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Booked</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.OrderByDescending(x => x.CreatedDate))
                        {
                            var statusClass = b.BookingStatus switch
                            {
                                BookingStatus.Confirmed  => "success",
                                BookingStatus.Cancelled  => "danger",
                                BookingStatus.CheckedIn  => "info",
                                BookingStatus.Boarded    => "primary",
                                BookingStatus.Completed  => "success",
                                _                        => "secondary"
                            };
                            <tr>
                                <td class="fw-bold font-monospace text-primary">@b.PnrNumber</td>
                                <td>@b.PassengerName</td>
                                <td class="fw-semibold">@b.FlightNumber</td>
                                <td>
                                    <span class="text-nowrap">@b.DepartureCity</span>
                                    <i class="bi bi-arrow-right text-muted mx-1"></i>
                                    <span class="text-nowrap">@b.ArrivalCity</span>
                                </td>
                                <td class="text-nowrap">@b.DepartureDateTime.ToString("dd MMM HH:mm")</td>
                                <td>
                                    <span class="fw-semibold">@b.SeatNumber</span>
                                    <span class="badge bg-light text-dark border ms-1">@b.SeatClass</span>
                                </td>
                                <td class="fw-semibold text-success text-nowrap">@b.TotalPrice.ToString("N0") @b.Currency</td>
                                <td><span class="badge bg-@statusClass">@b.BookingStatus</span></td>
                                <td class="text-muted">@b.CreatedDate.ToString("dd MMM")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
