@model DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var stats = ViewBag.PassengerStats as List<FlightPassengerStatViewModel> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Admin Dashboard</h2>
    <span class="text-muted small">Live Statistics</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="display-6 fw-bold text-primary">@Model.TotalUsers</div>
            <div class="text-muted small mt-1"><i class="bi bi-people me-1"></i>Total Users</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="display-6 fw-bold text-info">@Model.TotalFlights</div>
            <div class="text-muted small mt-1"><i class="bi bi-airplane me-1"></i>Total Flights</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="display-6 fw-bold text-success">@Model.TotalBookings</div>
            <div class="text-muted small mt-1"><i class="bi bi-ticket-perforated me-1"></i>Total Bookings</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center p-3 bg-success text-white">
            <div class="display-6 fw-bold">@Model.TotalRevenue.ToString("N0")</div>
            <div class="small mt-1 opacity-75"><i class="bi bi-currency-dollar me-1"></i>Total Revenue</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header fw-semibold bg-light">
                <i class="bi bi-airplane-fill me-2 text-primary"></i>Flight Status Breakdown
            </div>
            <div class="card-body">
                <div class="row g-2 text-center">
                    <div class="col-4">
                        <div class="p-2 rounded bg-primary bg-opacity-10">
                            <div class="fw-bold text-primary fs-4">@Model.ScheduledFlights</div>
                            <div class="text-muted small">Scheduled</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-warning bg-opacity-10">
                            <div class="fw-bold text-warning fs-4">@Model.BoardingFlights</div>
                            <div class="text-muted small">Boarding</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-info bg-opacity-10">
                            <div class="fw-bold text-info fs-4">@Model.DepartedFlights</div>
                            <div class="text-muted small">Departed</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-success bg-opacity-10">
                            <div class="fw-bold text-success fs-4">@Model.ArrivedFlights</div>
                            <div class="text-muted small">Arrived</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-warning bg-opacity-25">
                            <div class="fw-bold text-warning fs-4">@Model.DelayedFlights</div>
                            <div class="text-muted small">Delayed</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-danger bg-opacity-10">
                            <div class="fw-bold text-danger fs-4">@Model.CancelledFlights</div>
                            <div class="text-muted small">Cancelled</div>
                        </div>
                    </div>
                </div>
                <div class="mt-3 alert alert-primary py-2 small mb-0">
                    <i class="bi bi-clock me-1"></i>
                    <strong>@Model.UpcomingFlightsNext24Hours</strong> flights departing in the next 24 hours
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header fw-semibold bg-light">
                <i class="bi bi-ticket-perforated me-2 text-success"></i>Booking Status Breakdown
            </div>
            <div class="card-body">
                <div class="row g-2 text-center">
                    <div class="col-4">
                        <div class="p-2 rounded bg-success bg-opacity-10">
                            <div class="fw-bold text-success fs-4">@Model.ConfirmedBookings</div>
                            <div class="text-muted small">Confirmed</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-info bg-opacity-10">
                            <div class="fw-bold text-info fs-4">@Model.CheckedInBookings</div>
                            <div class="text-muted small">Checked In</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded bg-danger bg-opacity-10">
                            <div class="fw-bold text-danger fs-4">@Model.CancelledBookings</div>
                            <div class="text-muted small">Cancelled</div>
                        </div>
                    </div>
                </div>
                <div class="mt-3 d-grid gap-2">
                    <a asp-area="Admin" asp-controller="Booking" asp-action="Index"
                       class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-list-check me-1"></i>View All Bookings
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@if (stats.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-header fw-semibold bg-light">
            <i class="bi bi-bar-chart me-2 text-primary"></i>Flight Occupancy Stats
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th>Flight</th>
                            <th>Route</th>
                            <th>Departure</th>
                            <th>Status</th>
                            <th class="text-center">Pax</th>
                            <th class="text-center">Capacity</th>
                            <th>Occupancy</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in stats.OrderByDescending(x => x.OccupancyRate))
                        {
                            var occ = (int)s.OccupancyRate;
                            var barColor = occ >= 80 ? "bg-success" : occ >= 50 ? "bg-warning" : "bg-danger";
                            <tr>
                                <td class="fw-semibold font-monospace">@s.FlightNumber</td>
                                <td>@s.DepartureCity <i class="bi bi-arrow-right text-muted"></i> @s.ArrivalCity</td>
                                <td>@s.DepartureDateTime.ToString("dd MMM HH:mm")</td>
                                <td><span class="badge bg-secondary">@s.FlightStatus</span></td>
                                <td class="text-center">@s.PassengerCount</td>
                                <td class="text-center">@s.TotalCapacity</td>
                                <td style="min-width: 100px">
                                    <div class="d-flex align-items-center gap-1">
                                        <div class="progress flex-grow-1" style="height:8px">
                                            <div class="progress-bar @barColor" style="width: @occ%"></div>
                                        </div>
                                        <small class="fw-semibold">@s.OccupancyRate%</small>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
