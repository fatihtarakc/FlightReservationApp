@model AdminFlightFormPageVM

<div class="row justify-content-center">
    <div class="col-xl-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <i class="fas fa-edit me-2"></i>@L["Flight_Edit"] — <span class="text-warning">@Model.Form.FlightNumber</span>
            </div>
            <div class="p-4">
                <form asp-action="Edit" asp-route-id="@Model.EditId" method="post" novalidate
                      data-arrival-msg="@L["Val_ArrivalTime_AfterDeparture"]">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Form.FlightNumber" class="form-label fw-semibold">@L["Flight_Number"]</label>
                            <input asp-for="Form.FlightNumber" class="form-control" readonly/>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Form.ScheduleId" class="form-label fw-semibold">@L["Flight_Schedule"]</label>
                            <select asp-for="Form.ScheduleId" class="form-select" id="scheduleSelect" disabled>
                                <option value="">— @L["Flight_SelectSchedule"] —</option>
                                @foreach (var s in Model.Schedules)
                                {
                                    <option value="@s.Id" data-duration="@s.DurationMinutes">
                                        @s.Code · @s.DepartureAirport → @s.ArrivalAirport
                                    </option>
                                }
                            </select>
                            <small class="text-muted">@L["Flight_ScheduleReadOnly"]</small>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Form.AircraftId" class="form-label fw-semibold">@L["Flight_Aircraft"]</label>
                            <select asp-for="Form.AircraftId" class="form-select" disabled>
                                <option value="">— @L["Flight_SelectAircraft"] —</option>
                                @foreach (var a in Model.Aircraft)
                                {
                                    <option value="@a.Id" data-airline-id="@a.AirlineId">
                                        @a.RegistrationNumber · @a.Model · @a.Manufacturer — @L["Status_" + a.Status.ToString()]
                                    </option>
                                }
                            </select>
                            <small class="text-muted">@L["Flight_AircraftReadOnly"]</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.DepartureTime" class="form-label fw-semibold">@L["Flight_DepartureDateTime"]</label>
                            <input asp-for="Form.DepartureTime" type="datetime-local" class="form-control" readonly/>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.ArrivalTime" class="form-label fw-semibold">@L["Flight_ArrivalDateTime"]</label>
                            <input asp-for="Form.ArrivalTime" type="datetime-local" class="form-control" readonly/>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h6 class="fw-bold mb-3"><i class="fas fa-door-open me-2 text-secondary"></i>@L["Flight_GateTerminal"]</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Form.Gate" class="form-label fw-semibold">@L["Flight_Gate"]</label>
                            <input asp-for="Form.Gate" class="form-control" placeholder="A12"/>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Terminal" class="form-label fw-semibold">@L["Flight_Terminal"]</label>
                            <input asp-for="Form.Terminal" class="form-control" placeholder="T1"/>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h6 class="fw-bold mb-3"><i class="fas fa-tags me-2 text-danger"></i>@L["Flight_Pricing"]</h6>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="Form.EconomyPrice" class="form-label fw-semibold">@L["Flight_Economy"] (₺) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.EconomyPrice" class="form-control" type="number" min="1" step="0.01" required/>
                            </div>
                            <span asp-validation-for="Form.EconomyPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.PremiumEconomyPrice" class="form-label fw-semibold">@L["Flight_PremiumEconomy"] (₺) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.PremiumEconomyPrice" class="form-control" type="number" min="1" step="0.01" required
                                       data-gt-economy-msg="@L["Val_PremiumEconomy_GreaterThan_Economy"]"/>
                            </div>
                            <span asp-validation-for="Form.PremiumEconomyPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.BusinessPrice" class="form-label fw-semibold">@L["Flight_Business"] (₺) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.BusinessPrice" class="form-control" type="number" min="1" step="0.01" required
                                       data-gt-premium-msg="@L["Val_Business_GreaterThan_PremiumEconomy"]"/>
                            </div>
                            <span asp-validation-for="Form.BusinessPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.FirstClassPrice" class="form-label fw-semibold">@L["Flight_First"] (₺) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.FirstClassPrice" class="form-control" type="number" min="1" step="0.01" required
                                       data-gt-business-msg="@L["Val_FirstClass_GreaterThan_Business"]"/>
                            </div>
                            <span asp-validation-for="Form.FirstClassPrice" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4">
                            <i class="fas fa-save me-1"></i> @L["Btn_SaveChanges"]
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-form-validation.js"></script>
}
