@model AdminFlightFormPageVM
@{
    ViewData["Title"] = "Yeni Uçuş Ekle";
    ViewData["PageTitle"] = "Yeni Uçuş Ekle";
}

<div class="row justify-content-center">
    <div class="col-xl-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <i class="fas fa-plus me-2"></i>Yeni Uçuş Bilgileri
            </div>
            <div class="p-4">
                <form asp-action="Create" method="post" id="flightForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Form.FlightNumber" class="form-label fw-semibold">Uçuş Numarası <span class="text-danger">*</span></label>
                            <input asp-for="Form.FlightNumber" class="form-control" placeholder="SK001" />
                            <span asp-validation-for="Form.FlightNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Form.RouteId" class="form-label fw-semibold">Güzergah <span class="text-danger">*</span></label>
                            <select asp-for="Form.RouteId" class="form-select" id="routeSelect">
                                <option value="">— Güzergah Seçin —</option>
                                @foreach (var r in Model.Routes)
                                {
                                    <option value="@r.Id">@r.OriginIata → @r.DestinationIata (@r.OriginCity - @r.DestinationCity) · @r.EstimatedDuration dk</option>
                                }
                            </select>
                            <span asp-validation-for="Form.RouteId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Form.AircraftId" class="form-label fw-semibold">Uçak <span class="text-danger">*</span></label>
                            <select asp-for="Form.AircraftId" class="form-select">
                                <option value="">— Uçak Seçin —</option>
                                @foreach (var a in Model.Aircraft)
                                {
                                    <option value="@a.Id">@a.RegistrationNumber · @a.Model · @a.Manufacturer (@a.TotalSeats koltuk) — @a.Status</option>
                                }
                            </select>
                            <span asp-validation-for="Form.AircraftId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.DepartureTime" class="form-label fw-semibold">Kalkış Tarihi/Saati <span class="text-danger">*</span></label>
                            <input asp-for="Form.DepartureTime" type="datetime-local" class="form-control" />
                            <span asp-validation-for="Form.DepartureTime" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.ArrivalTime" class="form-label fw-semibold">Varış Tarihi/Saati <span class="text-danger">*</span></label>
                            <input asp-for="Form.ArrivalTime" type="datetime-local" class="form-control" />
                            <span asp-validation-for="Form.ArrivalTime" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h6 class="fw-bold mb-3"><i class="fas fa-tags me-2 text-danger"></i>Fiyatlandırma</h6>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="Form.EconomyPrice" class="form-label fw-semibold">Ekonomi (₺) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.EconomyPrice" class="form-control" type="number" min="0" step="0.01" />
                            </div>
                            <span asp-validation-for="Form.EconomyPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.PremiumEconomyPrice" class="form-label fw-semibold">Premium Ekonomi (₺)</label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.PremiumEconomyPrice" class="form-control" type="number" min="0" step="0.01" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.BusinessPrice" class="form-label fw-semibold">Business (₺)</label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.BusinessPrice" class="form-control" type="number" min="0" step="0.01" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.FirstClassPrice" class="form-label fw-semibold">First Class (₺)</label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.FirstClassPrice" class="form-control" type="number" min="0" step="0.01" />
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="fas fa-save me-1"></i> Uçuş Ekle
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('routeSelect').addEventListener('change', function() {
        const opt = this.options[this.selectedIndex];
        if (opt.value) {
            const match = opt.text.match(/(\d+)\s*dk/);
            if (match) {
                const dep = document.querySelector('[name="Form.DepartureTime"]').value;
                if (dep) {
                    const d = new Date(dep);
                    d.setMinutes(d.getMinutes() + parseInt(match[1]));
                    document.querySelector('[name="Form.ArrivalTime"]').value = d.toISOString().slice(0,16);
                }
            }
        }
    });
    document.querySelector('[name="Form.DepartureTime"]').addEventListener('change', function() {
        document.getElementById('routeSelect').dispatchEvent(new Event('change'));
    });
</script>
}
