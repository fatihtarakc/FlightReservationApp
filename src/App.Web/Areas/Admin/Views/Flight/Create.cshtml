@model AdminFlightFormPageVM

<div class="row justify-content-center">
    <div class="col-xl-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <i class="fas fa-plus me-2"></i>@L["Flight_Add"]
            </div>
            <div class="p-4">
                <form asp-action="Create" method="post" id="flightForm" novalidate
                      data-arrival-msg="@L["Val_ArrivalTime_AfterDeparture"]">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Form.FlightNumber" class="form-label fw-semibold">@L["Flight_Number"] <span class="text-danger">*</span></label>
                            <input asp-for="Form.FlightNumber" class="form-control" placeholder="SK001" required/>
                            <span asp-validation-for="Form.FlightNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="Form.ScheduleId" class="form-label fw-semibold">@L["Flight_Schedule"] <span class="text-danger">*</span></label>
                            <select asp-for="Form.ScheduleId" class="form-select" id="scheduleSelect" required>
                                <option value="">— @L["Flight_SelectSchedule"] —</option>
                                @foreach (var s in Model.Schedules)
                                {
                                    <option value="@s.Id" data-duration="@s.DurationMinutes">
                                        @s.Code · @s.DepartureAirport → @s.ArrivalAirport
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="Form.ScheduleId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Form.AircraftId" class="form-label fw-semibold">@L["Flight_Aircraft"] <span class="text-danger">*</span></label>
                            <select asp-for="Form.AircraftId" class="form-select" id="aircraftSelect" required>
                                <option value="">— @L["Flight_SelectAircraft"] —</option>
                                @foreach (var a in Model.Aircraft)
                                {
                                    <option value="@a.Id" data-airline-id="@a.AirlineId">
                                        @a.RegistrationNumber · @a.Model · @a.Manufacturer — @L["Status_" + a.Status.ToString()]
                                    </option>
                                }
                            </select>
                            <input asp-for="Form.AirlineId" type="hidden" id="airlineIdInput" />
                            <span asp-validation-for="Form.AircraftId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.DepartureTime" class="form-label fw-semibold">@L["Flight_DepartureDateTime"] <span class="text-danger">*</span></label>
                            <input asp-for="Form.DepartureTime" type="datetime-local" class="form-control" required/>
                            <span asp-validation-for="Form.DepartureTime" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.ArrivalTime" class="form-label fw-semibold">@L["Flight_ArrivalDateTime"] <span class="text-danger">*</span></label>
                            <input asp-for="Form.ArrivalTime" type="datetime-local" class="form-control" required/>
                            <span asp-validation-for="Form.ArrivalTime" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h6 class="fw-bold mb-3"><i class="fas fa-tags me-2 text-danger"></i>@L["Flight_Pricing"]</h6>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="Form.EconomyPrice" class="form-label fw-semibold">@L["Flight_Economy"] (₺) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.EconomyPrice" class="form-control" type="number" min="0" step="0.01" required/>
                            </div>
                            <span asp-validation-for="Form.EconomyPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.PremiumEconomyPrice" class="form-label fw-semibold">@L["Flight_PremiumEconomy"] (₺)</label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.PremiumEconomyPrice" class="form-control" type="number" min="0" step="0.01"/>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.BusinessPrice" class="form-label fw-semibold">@L["Flight_Business"] (₺)</label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.BusinessPrice" class="form-control" type="number" min="0" step="0.01"/>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Form.FirstClassPrice" class="form-label fw-semibold">@L["Flight_First"] (₺)</label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Form.FirstClassPrice" class="form-control" type="number" min="0" step="0.01"/>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="fas fa-save me-1"></i> @L["Flight_Add"]
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-form-validation.js"></script>
}
