@model AircraftUpdateVM
@{
    var editId = ViewContext.RouteData.Values["id"];
}

<div class="row justify-content-center">
    <div class="col-xl-7">
        <div class="admin-card">
            <div class="admin-card-header"><i class="fas fa-fighter-jet me-2"></i>@L["Aircraft_Management"] — @L["Btn_Edit"]</div>
            <div class="p-4">
                <form asp-action="Edit" asp-route-id="@editId" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="TailNumber" class="form-label fw-semibold">@L["Aircraft_Registration"] <span class="text-danger">*</span></label>
                            <input asp-for="TailNumber" class="form-control" placeholder="TC-SKY" />
                            <span asp-validation-for="TailNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ManufactureYear" class="form-label fw-semibold">@L["Aircraft_ManufactureYear"] <span class="text-danger">*</span></label>
                            <input asp-for="ManufactureYear" class="form-control" type="number" min="1950" max="2030" />
                            <span asp-validation-for="ManufactureYear" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AirlineId" class="form-label fw-semibold">@L["Aircraft_Manufacturer"] <span class="text-danger">*</span></label>
                            <select id="airlineSelect" asp-for="AirlineId" class="form-select"
                                    data-selected="@Model.AirlineId">
                                <option value="">— @L["Label_SelectOption"] —</option>
                            </select>
                            <span asp-validation-for="AirlineId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ModelId" class="form-label fw-semibold">@L["Aircraft_Model"] <span class="text-danger">*</span></label>
                            <select id="modelSelect" asp-for="ModelId" class="form-select"
                                    data-selected="@Model.ModelId">
                                <option value="">— @L["Label_SelectOption"] —</option>
                            </select>
                            <span asp-validation-for="ModelId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AircraftStatus" class="form-label fw-semibold">@L["Label_Status"]</label>
                            <select asp-for="AircraftStatus" class="form-select">
                                @foreach (var s in Enum.GetValues<AircraftStatus>())
                                {
                                    <option value="@((int)s)">@L["Status_" + s.ToString()]</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4"><i class="fas fa-save me-1"></i> @L["Btn_Save"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/aircraft-form.js"></script>
    <script src="~/js/admin-form-validation.js"></script>
}
