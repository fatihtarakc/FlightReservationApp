@model AdminAircraftListPageVM

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-fighter-jet me-2"></i>@L["Aircraft_Fleet"]</span>
        <a asp-area="Admin" asp-controller="Aircraft" asp-action="Create" class="btn btn-sm btn-danger">
            <i class="fas fa-plus me-1"></i> @L["Aircraft_New"]
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>@L["Aircraft_Registration"]</th>
                    <th>@L["Aircraft_ModelManufacturer"]</th>
                    <th>@L["Aircraft_ManufactureYear"]</th>
                    <th>@L["Label_Status"]</th>
                    <th class="text-center">@L["Label_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Aircraft.Any())
                {
                    @foreach (var a in Model.Aircraft)
                    {
                        <tr>
                            <td><strong class="text-danger">@a.RegistrationNumber</strong></td>
                            <td>
                                @a.Model<br />
                                <small class="text-muted">@a.Manufacturer</small>
                            </td>
                            <td>@a.ManufactureYear</td>
                            <td>
                                @{
                                    var sc = a.Status switch {
                                        AircraftStatus.Active      => "bg-success",
                                        AircraftStatus.Maintenance => "bg-warning text-dark",
                                        AircraftStatus.Retired     => "bg-secondary",
                                        _                          => "bg-secondary"
                                    };
                                }
                                <span class="badge @sc">@L["Status_" + a.Status.ToString()]</span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-outline-primary" title="@L["Btn_Edit"]">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('@L["Confirm_Delete"]')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger" title="@L["Btn_Delete"]">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">
                        <i class="fas fa-fighter-jet fa-2x mb-2 d-block"></i>@L["Aircraft_NotFound"]
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
