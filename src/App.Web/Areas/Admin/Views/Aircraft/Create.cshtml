@model AircraftAddVM

<div class="row justify-content-center">
    <div class="col-xl-7">
        <div class="admin-card">
            <div class="admin-card-header"><i class="fas fa-fighter-jet me-2"></i>@L["Aircraft_Management"] — @L["Btn_Add"]</div>
            <div class="p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="RegistrationNumber" class="form-label fw-semibold">@L["Aircraft_Registration"] <span class="text-danger">*</span></label>
                            <input asp-for="RegistrationNumber" class="form-control" placeholder="TC-SKY" />
                            <span asp-validation-for="RegistrationNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label fw-semibold">@L["Aircraft_Model"] <span class="text-danger">*</span></label>
                            <input asp-for="Model" class="form-control" placeholder="Boeing 737-800" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Manufacturer" class="form-label fw-semibold">@L["Aircraft_Manufacturer"] <span class="text-danger">*</span></label>
                            <select asp-for="Manufacturer" class="form-select">
                                <option value="">— @L["Aircraft_Manufacturer"] —</option>
                                <option value="Boeing">Boeing</option>
                                <option value="Airbus">Airbus</option>
                                <option value="Embraer">Embraer</option>
                                <option value="Bombardier">Bombardier</option>
                                <option value="ATR">ATR</option>
                            </select>
                            <span asp-validation-for="Manufacturer" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BodyType" class="form-label fw-semibold">@L["Aircraft_BodyType"] <span class="text-danger">*</span></label>
                            <select asp-for="BodyType" class="form-select">
                                @foreach (var bt in Enum.GetValues<BodyType>())
                                {
                                    <option value="@((int)bt)">@bt</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TotalSeats" class="form-label fw-semibold">@L["Aircraft_TotalSeats"] <span class="text-danger">*</span></label>
                            <input asp-for="TotalSeats" class="form-control" type="number" min="1" />
                            <span asp-validation-for="TotalSeats" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EconomySeats" class="form-label fw-semibold">@L["Aircraft_EconomySeats"]</label>
                            <input asp-for="EconomySeats" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BusinessSeats" class="form-label fw-semibold">@L["Aircraft_BusinessSeats"]</label>
                            <input asp-for="BusinessSeats" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold">@L["Label_Status"]</label>
                            <select asp-for="Status" class="form-select">
                                @foreach (var s in Enum.GetValues<AircraftStatus>())
                                {
                                    <option value="@((int)s)">@L["Status_" + s.ToString()]</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ManufactureYear" class="form-label fw-semibold">@L["Aircraft_ManufactureYear"]</label>
                            <input asp-for="ManufactureYear" class="form-control" type="number" min="1950" max="2030" />
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4"><i class="fas fa-save me-1"></i> @L["Aircraft_Add"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
