@model AircraftVM

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-fighter-jet me-2"></i>@L["Aircraft_Detail"]</span>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-edit me-1"></i>@L["Btn_Edit"]
            </a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>@L["Btn_Back"]
            </a>
        </div>
    </div>

    <div class="p-4 border-bottom bg-light text-center">
        <div class="display-6 fw-bold text-danger"><i class="fas fa-fighter-jet me-3"></i>@Model.RegistrationNumber</div>
        <div class="text-muted mt-1">@Model.Manufacturer — @Model.Model</div>
    </div>

    <div class="p-4">
        <div class="row justify-content-center">
            <div class="col-md-6">
                @{
                    var sc = Model.Status switch {
                        AircraftStatus.Active      => "bg-success",
                        AircraftStatus.Maintenance => "bg-warning text-dark",
                        AircraftStatus.Retired     => "bg-secondary",
                        _                          => "bg-secondary"
                    };
                }
                <table class="table table-sm table-borderless">
                    <tr>
                        <td class="text-muted fw-semibold" style="width:45%">@L["Aircraft_Registration"]</td>
                        <td><strong class="text-danger">@Model.RegistrationNumber</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Aircraft_Manufacturer"]</td>
                        <td>@Model.Manufacturer</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Aircraft_Model"]</td>
                        <td>@Model.Model</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Aircraft_ManufactureYear"]</td>
                        <td>@Model.ManufactureYear</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Label_Status"]</td>
                        <td><span class="badge @sc">@L["Status_" + Model.Status.ToString()]</span></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
