@model AdminRouteEditPageVM

<div class="row justify-content-center">
    <div class="col-xl-7">
        <div class="admin-card">
            <div class="admin-card-header"><i class="fas fa-edit me-2"></i>@L["Route_Edit"]</div>
            <div class="p-4">
                <form asp-action="Edit" asp-route-id="@Model.EditId" method="post" id="routeForm" novalidate data-same-airport-msg="@L["Error_SameAirport"]">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Form.OriginAirportId" class="form-label fw-semibold">@L["Route_Origin"]</label>
                            <select asp-for="Form.OriginAirportId" class="form-select" disabled>
                                @foreach (var a in Model.Airports)
                                {
                                    @if (Model.Form.OriginAirportId == a.Id)
                                    {
                                        <option value="@a.Id" selected>@a.IataCode · @a.Name (@a.City, @a.Country)</option>
                                    }
                                    else
                                    {
                                        <option value="@a.Id">@a.IataCode · @a.Name (@a.City, @a.Country)</option>
                                    }
                                }
                            </select>
                            <small class="text-muted">@L["Route_AirportsReadOnly"]</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.DestinationAirportId" class="form-label fw-semibold">@L["Route_Destination"]</label>
                            <select asp-for="Form.DestinationAirportId" class="form-select" disabled>
                                @foreach (var a in Model.Airports)
                                {
                                    @if (Model.Form.DestinationAirportId == a.Id)
                                    {
                                        <option value="@a.Id" selected>@a.IataCode · @a.Name (@a.City, @a.Country)</option>
                                    }
                                    else
                                    {
                                        <option value="@a.Id">@a.IataCode · @a.Name (@a.City, @a.Country)</option>
                                    }
                                }
                            </select>
                            <small class="text-muted">@L["Route_AirportsReadOnly"]</small>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.DistanceKm" class="form-label fw-semibold">@L["Route_Distance"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Form.DistanceKm" class="form-control" type="number" min="1" required/>
                                <span class="input-group-text">km</span>
                            </div>
                            <span asp-validation-for="Form.DistanceKm" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.EstimatedDuration" class="form-label fw-semibold">@L["Route_Duration"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Form.EstimatedDuration" class="form-control" type="number" min="1" required/>
                                <span class="input-group-text">dk</span>
                            </div>
                            <span asp-validation-for="Form.EstimatedDuration" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4"><i class="fas fa-save me-1"></i> @L["Btn_Save"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-form-validation.js"></script>
}

