@model AdminRouteFormPageVM

<div class="row justify-content-center">
    <div class="col-xl-7">
        <div class="admin-card">
            <div class="admin-card-header"><i class="fas fa-route me-2"></i>@L["Route_Info"]</div>
            <div class="p-4">
                <form asp-action="Create" method="post" id="routeForm" novalidate data-same-airport-msg="@L["Error_SameAirport"]">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Form.OriginAirportId" class="form-label fw-semibold">@L["Route_Origin"] <span class="text-danger">*</span></label>
                            <select asp-for="Form.OriginAirportId" class="form-select" id="originSelect" required>
                                <option value="">— @L["Route_SelectOrigin"] —</option>
                                @foreach (var a in Model.Airports)
                                {
                                    <option value="@a.Id" data-iata="@a.IataCode" data-city="@a.City">
                                        @a.IataCode · @a.Name (@a.City, @a.Country)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="Form.OriginAirportId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.DestinationAirportId" class="form-label fw-semibold">@L["Route_Destination"] <span class="text-danger">*</span></label>
                            <select asp-for="Form.DestinationAirportId" class="form-select" id="destinationSelect" required>
                                <option value="">— @L["Route_SelectDestination"] —</option>
                                @foreach (var a in Model.Airports)
                                {
                                    <option value="@a.Id" data-iata="@a.IataCode" data-city="@a.City">
                                        @a.IataCode · @a.Name (@a.City, @a.Country)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="Form.DestinationAirportId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.DistanceKm" class="form-label fw-semibold">@L["Route_Distance"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Form.DistanceKm" class="form-control" type="number" min="1" required/>
                                <span class="input-group-text">km</span>
                            </div>
                            <span asp-validation-for="Form.DistanceKm" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Form.EstimatedDuration" class="form-label fw-semibold">@L["Route_Duration"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Form.EstimatedDuration" class="form-control" type="number" min="1" required/>
                                <span class="input-group-text">dk</span>
                            </div>
                            <span asp-validation-for="Form.EstimatedDuration" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4"><i class="fas fa-save me-1"></i> @L["Route_Add"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-form-validation.js"></script>
    <script>
    (function () {
        var originSel = document.getElementById('originSelect');
        var destSel   = document.getElementById('destinationSelect');
        if (!originSel || !destSel) return;

        var originalHtml = destSel.innerHTML;

        originSel.addEventListener('change', function () {
            var depId = this.value;

            destSel.innerHTML = originalHtml;
            destSel.value = '';

            if (!depId) return;

            fetch('@Url.Action("GetTakenDestinations", "Route", new { area = "Admin" })?departureAirportId=' + depId)
                .then(function (r) { return r.json(); })
                .then(function (takenIds) {
                    var takenSet = new Set(takenIds.map(function (id) { return id.toLowerCase(); }));
                    var depIdLow = depId.toLowerCase();

                    Array.from(destSel.options).forEach(function (opt) {
                        if (!opt.value) return;
                        var v = opt.value.toLowerCase();
                        if (v === depIdLow || takenSet.has(v)) opt.remove();
                    });

                    if (destSel.value && !destSel.querySelector('option[value="' + destSel.value + '"]'))
                        destSel.value = '';
                })
                .catch(function () {});
        });
    })();
    </script>
}
