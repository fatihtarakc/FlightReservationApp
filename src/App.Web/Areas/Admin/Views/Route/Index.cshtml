@model AdminRouteListPageVM

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-route me-2"></i>@L["Route_All"]</span>
        <a asp-area="Admin" asp-controller="Route" asp-action="Create" class="btn btn-sm btn-danger">
            <i class="fas fa-plus me-1"></i> @L["Route_New"]
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>@L["Route_Origin"]</th>
                    <th>@L["Route_Destination"]</th>
                    <th>@L["Flight_Route"]</th>
                    <th>@L["Route_Distance"]</th>
                    <th>@L["Route_Duration"]</th>
                    <th class="text-center">@L["Label_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Routes.Any())
                {
                    @foreach (var r in Model.Routes)
                    {
                        <tr>
                            <td>
                                <strong>@r.OriginIata</strong><br />
                                <small class="text-muted">@r.OriginCity</small>
                            </td>
                            <td>
                                <strong>@r.DestinationIata</strong><br />
                                <small class="text-muted">@r.DestinationCity</small>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@r.OriginIata</span>
                                <i class="fas fa-long-arrow-alt-right text-muted mx-2"></i>
                                <span class="badge bg-secondary">@r.DestinationIata</span>
                            </td>
                            <td>@r.DistanceKm km</td>
                            <td>@r.DurationMinutes dk</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-outline-primary" title="@L["Btn_Edit"]">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('@L["Confirm_Delete"]')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger" title="@L["Btn_Delete"]">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">
                        <i class="fas fa-route fa-2x mb-2 d-block"></i>@L["Route_NotFound"]
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
