@model AdminNotificationListPageVM

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-bell me-2"></i>@L["Notif_History"]</span>
    </div>

    <div class="p-3 border-bottom bg-light">
        <form method="get" class="row g-2">
            <div class="col-md-3">
                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm"
                       placeholder="@L["Placeholder_SearchNotif"]" />
            </div>
            <div class="col-md-2">
                <select name="channel" class="form-select form-select-sm">
                    <option value="">@L["Notif_AllChannels"]</option>
                    @if (Model.Channel == "Email")
                    {
                        <option value="Email" selected>@L["Notif_Email"]</option>
                    }
                    else
                    {
                        <option value="Email">@L["Notif_Email"]</option>
                    }
                    @if (Model.Channel == "Sms")
                    {
                        <option value="Sms" selected>@L["Notif_Sms"]</option>
                    }
                    else
                    {
                        <option value="Sms">@L["Notif_Sms"]</option>
                    }
                    @if (Model.Channel == "WhatsApp")
                    {
                        <option value="WhatsApp" selected>@L["Notif_WhatsApp"]</option>
                    }
                    else
                    {
                        <option value="WhatsApp">@L["Notif_WhatsApp"]</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="success" class="form-select form-select-sm">
                    <option value="">@L["Notif_AllStatuses"]</option>
                    <option value="true">@L["Notif_Success"]</option>
                    <option value="false">@L["Notif_Failed"]</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="date" value="@Model.DateFilter" class="form-control form-control-sm" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-secondary"><i class="fas fa-search me-1"></i>@L["Btn_Filter"]</button>
                <a asp-action="Notifications" class="btn btn-sm btn-outline-secondary ms-1">@L["Btn_Clear"]</a>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 small">
            <thead class="table-dark">
                <tr>
                    <th>@L["Notif_Channel"]</th>
                    <th>@L["Notif_Recipient"]</th>
                    <th>@L["Notif_Subject"]</th>
                    <th>@L["Notif_SentAt"]</th>
                    <th>@L["Label_Status"]</th>
                    <th>@L["Notif_Error"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Notifications.Any())
                {
                    @foreach (var n in Model.Notifications)
                    {
                        <tr>
                            <td>
                                @{
                                    var icon = n.Channel switch {
                                        "Email" => "fas fa-envelope text-primary",
                                        "Sms" => "fas fa-sms text-success",
                                        "WhatsApp" => "fab fa-whatsapp text-success",
                                        _ => "fas fa-bell"
                                    };
                                }
                                <i class="@icon me-1"></i> @n.Channel
                            </td>
                            <td>@n.Recipient</td>
                            <td>@n.Subject</td>
                            <td>@n.SentAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (n.IsSuccess)
                                {
                                    <span class="badge bg-success">@L["Notif_Success"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@L["Notif_Failed"]</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(n.ErrorMessage))
                                {
                                    <span class="text-danger" title="@n.ErrorMessage" style="cursor:help">
                                        <i class="fas fa-exclamation-circle"></i> @n.ErrorMessage.Substring(0, Math.Min(40, n.ErrorMessage.Length))...
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">
                        <i class="fas fa-bell-slash fa-2x mb-2 d-block"></i>@L["Notif_NotFound"]
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="row mt-4 g-3">
    <div class="col-md-4">
        <div class="admin-stat-card" style="border-left:4px solid #1565c0">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">@L["Notif_EmailSent"]</div>
                    <div class="stat-value">@Model.EmailCount</div>
                </div>
                <div class="stat-icon" style="background:rgba(21,101,192,.1);color:#1565c0"><i class="fas fa-envelope"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="admin-stat-card" style="border-left:4px solid #2e7d32">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">@L["Notif_SmsSent"]</div>
                    <div class="stat-value">@Model.SmsCount</div>
                </div>
                <div class="stat-icon" style="background:rgba(46,125,50,.1);color:#2e7d32"><i class="fas fa-sms"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="admin-stat-card" style="border-left:4px solid #25d366">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">@L["Notif_WhatsAppSent"]</div>
                    <div class="stat-value">@Model.WhatsAppCount</div>
                </div>
                <div class="stat-icon" style="background:rgba(37,211,102,.1);color:#25d366"><i class="fab fa-whatsapp"></i></div>
            </div>
        </div>
    </div>
</div>
