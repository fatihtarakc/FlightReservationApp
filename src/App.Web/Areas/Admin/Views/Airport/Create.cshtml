@model AirportAddVM

<div class="row justify-content-center">
    <div class="col-xl-7">
        <div class="admin-card">
            <div class="admin-card-header"><i class="fas fa-map-marker-alt me-2"></i>@L["Airport_Management"] — @L["Btn_Add"]</div>
            <div class="p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="IataCode" class="form-label fw-semibold">@L["Airport_IataCode"] <span class="text-danger">*</span></label>
                            <input asp-for="IataCode" class="form-control text-uppercase" maxlength="3" placeholder="IST" />
                            <span asp-validation-for="IataCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label fw-semibold">@L["Airport_Name"] <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="City" class="form-label fw-semibold">@L["Airport_City"] <span class="text-danger">*</span></label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Country" class="form-label fw-semibold">@L["Airport_Country"] <span class="text-danger">*</span></label>
                            <select asp-for="Country" class="form-select">
                                <option value="">— @L["Airport_SelectCountry"] —</option>
                                <option value="Türkiye">Türkiye</option>
                                <option value="ABD">ABD</option>
                                <option value="Almanya">Almanya</option>
                                <option value="Fransa">Fransa</option>
                                <option value="İngiltere">İngiltere</option>
                                <option value="İtalya">İtalya</option>
                                <option value="İspanya">İspanya</option>
                                <option value="Hollanda">Hollanda</option>
                                <option value="BAE">BAE</option>
                                <option value="Katar">Katar</option>
                                <option value="Japonya">Japonya</option>
                                <option value="Çin">Çin</option>
                                <option value="Hindistan">Hindistan</option>
                                <option value="Rusya">Rusya</option>
                                <option value="Diğer">Diğer</option>
                            </select>
                            <span asp-validation-for="Country" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Timezone" class="form-label fw-semibold">@L["Airport_Timezone"] <span class="text-danger">*</span></label>
                            <select asp-for="Timezone" class="form-select">
                                <option value="">— @L["Airport_SelectTimezone"] —</option>
                                <option value="Europe/Istanbul">Europe/Istanbul (UTC+3)</option>
                                <option value="Europe/London">Europe/London (UTC+0/+1)</option>
                                <option value="Europe/Berlin">Europe/Berlin (UTC+1/+2)</option>
                                <option value="Europe/Paris">Europe/Paris (UTC+1/+2)</option>
                                <option value="America/New_York">America/New_York (UTC-5/-4)</option>
                                <option value="America/Los_Angeles">America/Los_Angeles (UTC-8/-7)</option>
                                <option value="Asia/Dubai">Asia/Dubai (UTC+4)</option>
                                <option value="Asia/Tokyo">Asia/Tokyo (UTC+9)</option>
                                <option value="Asia/Shanghai">Asia/Shanghai (UTC+8)</option>
                            </select>
                            <span asp-validation-for="Timezone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Latitude" class="form-label fw-semibold">@L["Airport_Latitude"]</label>
                            <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Longitude" class="form-label fw-semibold">@L["Airport_Longitude"]</label>
                            <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4"><i class="fas fa-save me-1"></i> @L["Airport_Add"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

