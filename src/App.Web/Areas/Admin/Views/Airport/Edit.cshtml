@model AirportAddVM

<div class="row justify-content-center">
    <div class="col-xl-8">
        <div class="admin-card">
            <div class="admin-card-header"><i class="fas fa-map-marker-alt me-2"></i>@L["Airport_Management"] — @L["Btn_Edit"]</div>
            <div class="p-4">
                <form asp-action="Edit" asp-route-id="@ViewContext.RouteData.Values["id"]" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="IataCode" class="form-label fw-semibold">@L["Airport_IataCode"] <span class="text-danger">*</span></label>
                            <input asp-for="IataCode" class="form-control text-uppercase" maxlength="3" placeholder="IST" required/>
                            <span asp-validation-for="IataCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IcaoCode" class="form-label fw-semibold">ICAO</label>
                            <input asp-for="IcaoCode" class="form-control text-uppercase" maxlength="4" placeholder="LTFM"/>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="City" class="form-label fw-semibold">@L["Airport_City"] <span class="text-danger">*</span></label>
                            <input asp-for="City" class="form-control" required/>
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label fw-semibold">@L["Airport_Name"] <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required/>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Country" class="form-label fw-semibold">@L["Airport_Country"] <span class="text-danger">*</span></label>
                            <select id="countrySelect" name="Country" data-selected="@Model.Country" class="form-select" required>
                                <option value="">— @L["Airport_SelectCountry"] —</option>
                            </select>
                            <span asp-validation-for="Country" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Timezone" class="form-label fw-semibold">@L["Airport_Timezone"] <span class="text-danger">*</span></label>
                            <select id="timezoneSelect" name="Timezone" data-selected="@Model.Timezone" class="form-select" required>
                                <option value="">— @L["Airport_SelectTimezone"] —</option>
                            </select>
                            <span asp-validation-for="Timezone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Latitude" class="form-label fw-semibold">@L["Airport_Latitude"]</label>
                            <input asp-for="Latitude" class="form-control" type="number" step="0.000001"/>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Longitude" class="form-label fw-semibold">@L["Airport_Longitude"]</label>
                            <input asp-for="Longitude" class="form-control" type="number" step="0.000001"/>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4"><i class="fas fa-save me-1"></i> @L["Btn_Save"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/airport-form.js"></script>
    <script src="~/js/admin-form-validation.js"></script>
}
