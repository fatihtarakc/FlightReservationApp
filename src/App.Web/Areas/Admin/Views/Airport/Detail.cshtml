@model AirportVM

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-map-marker-alt me-2"></i>@L["Airport_Detail"]</span>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-edit me-1"></i>@L["Btn_Edit"]
            </a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>@L["Btn_Back"]
            </a>
        </div>
    </div>

    <div class="p-4 border-bottom bg-light text-center">
        <span class="badge bg-danger" style="font-size:2.5rem;padding:.5rem 1.5rem">@Model.IataCode</span>
        <div class="mt-3">
            <div class="fs-4 fw-semibold">@Model.Name</div>
            <div class="text-muted">@Model.City, @Model.Country</div>
        </div>
    </div>

    <div class="p-4">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <table class="table table-sm table-borderless">
                    <tr>
                        <td class="text-muted fw-semibold" style="width:45%">@L["Airport_IataCode"]</td>
                        <td><span class="badge bg-danger fs-6">@Model.IataCode</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Airport_IcaoCode"]</td>
                        <td><code>@Model.IcaoCode</code></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Airport_Name"]</td>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Airport_City"]</td>
                        <td>@Model.City</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Airport_Country"]</td>
                        <td>@Model.Country</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">@L["Airport_Timezone"]</td>
                        <td><small class="text-muted">@Model.Timezone</small></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
