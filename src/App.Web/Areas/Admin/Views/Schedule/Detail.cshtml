@model ScheduleVM

@{
    var dayDefs = new (DaysOfWeek Flag, string Label)[]
    {
        (DaysOfWeek.Monday,    L["DayOfWeek_Monday"].Value),
        (DaysOfWeek.Tuesday,   L["DayOfWeek_Tuesday"].Value),
        (DaysOfWeek.Wednesday, L["DayOfWeek_Wednesday"].Value),
        (DaysOfWeek.Thursday,  L["DayOfWeek_Thursday"].Value),
        (DaysOfWeek.Friday,    L["DayOfWeek_Friday"].Value),
        (DaysOfWeek.Saturday,  L["DayOfWeek_Saturday"].Value),
        (DaysOfWeek.Sunday,    L["DayOfWeek_Sunday"].Value)
    };
}

<div class="admin-card">
    <div class="admin-card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-calendar-alt me-2"></i>@L["Schedule_Detail"]</span>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-edit me-1"></i>@L["Btn_Edit"]
            </a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>@L["Btn_Back"]
            </a>
        </div>
    </div>

    <!-- Route banner -->
    <div class="p-4 border-bottom text-center bg-light">
        <div class="d-flex align-items-center justify-content-center gap-4">
            <div>
                <div class="display-5 fw-bold text-danger">@Model.DepartureAirport</div>
            </div>
            <div class="px-3 text-center">
                <i class="fas fa-long-arrow-alt-right fa-3x text-muted"></i>
                <div class="mt-2">
                    <span class="badge bg-secondary fs-6">@Model.Code</span>
                </div>
            </div>
            <div>
                <div class="display-5 fw-bold text-danger">@Model.ArrivalAirport</div>
            </div>
        </div>
    </div>

    <div class="p-4">
        <div class="row g-4">

            <!-- Timing -->
            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100">
                    <h6 class="text-danger mb-3 pb-2 border-bottom">
                        <i class="fas fa-clock me-2"></i>@L["Schedule_DepartureTime"]
                    </h6>
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="text-muted fw-semibold" style="width:45%">@L["Schedule_DepartureTime"]</td>
                            <td><code class="fs-5">@Model.DepartureTime.ToString(@"hh\:mm")</code></td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">@L["Schedule_TimeZone"]</td>
                            <td><small>@Model.TimeZone</small></td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">@L["Schedule_ValidFrom"]</td>
                            <td>@Model.ValidFrom.ToString("dd.MM.yyyy")</td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">@L["Schedule_ValidTo"]</td>
                            <td>@(Model.ValidTo.HasValue ? Model.ValidTo.Value.ToString("dd.MM.yyyy") : "—")</td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Days -->
            <div class="col-md-6">
                <div class="border rounded-3 p-3 h-100">
                    <h6 class="text-danger mb-3 pb-2 border-bottom">
                        <i class="fas fa-calendar-week me-2"></i>@L["Schedule_DaysOfWeek"]
                    </h6>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        @foreach (var (flag, label) in dayDefs)
                        {
                            var active = Model.DaysOfWeek.HasFlag(flag);
                            <span class="badge fs-6 px-3 py-2 @(active ? "bg-danger" : "bg-light text-muted border")">
                                @label
                            </span>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
