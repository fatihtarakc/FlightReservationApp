<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @{
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        var pageTitle = (ctrl, action) switch {
            ("Home", "Hangfire") => L["Admin_Hangfire"].Value,
            ("Home", "Logs") => L["Admin_Logs"].Value,
            ("Home", "Notifications") => L["Admin_Notifications"].Value,
            ("Home", _) => L["Admin_Dashboard"].Value,
            ("Flight", "Create") => L["Flight_Add"].Value,
            ("Flight", "Edit") => L["Flight_Edit"].Value,
            ("Flight", _) => L["Flight_Management"].Value,
            ("Aircraft", "Create") => L["Aircraft_Add"].Value,
            ("Aircraft", "Edit") => L["Aircraft_Edit"].Value,
            ("Aircraft", _) => L["Aircraft_Management"].Value,
            ("Airport", "Create") => L["Airport_Add"].Value,
            ("Airport", "Edit") => L["Airport_Edit"].Value,
            ("Airport", _) => L["Airport_Management"].Value,
            ("Route", "Create") => L["Route_Add"].Value,
            ("Route", _) => L["Route_Management"].Value,
            ("Booking", _) => L["Booking_Management"].Value,
            ("User", _) => L["Admin_UserManagement"].Value,
            _ => "SkyWay Admin"
        };
    }
    <title>@pageTitle - SkyWay Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root { --admin-primary: #1a1a2e; --admin-accent: #c8102e; --admin-sidebar: #16213e; }
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .admin-sidebar { width: 260px; min-height: 100vh; background: var(--admin-sidebar); position: fixed; top: 0; left: 0; z-index: 100; overflow-y: auto; }
        .admin-sidebar .brand { padding: 20px; border-bottom: 1px solid rgba(255,255,255,.1); }
        .admin-sidebar .brand a { color: #fff; text-decoration: none; font-size: 1.2rem; font-weight: 800; }
        .admin-sidebar .brand span { color: var(--admin-accent); }
        .admin-sidebar .nav-section { padding: 12px 20px 5px; font-size: .68rem; font-weight: 700; text-transform: uppercase; color: rgba(255,255,255,.35); letter-spacing: 1.5px; }
        .admin-sidebar .nav-link { color: rgba(255,255,255,.7); padding: 10px 20px; display: flex; align-items: center; gap: 10px; transition: all .2s; font-size: .875rem; border-left: 3px solid transparent; }
        .admin-sidebar .nav-link:hover, .admin-sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,.08); border-left-color: var(--admin-accent); }
        .admin-sidebar .nav-link i { width: 18px; text-align: center; font-size: .85rem; }
        .admin-content { margin-left: 260px; min-height: 100vh; }
        .admin-topbar { background: #fff; padding: 0 24px; height: 60px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 1px 4px rgba(0,0,0,.1); position: sticky; top: 0; z-index: 99; }
        .admin-body { padding: 24px; }
        .admin-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.06); margin-bottom: 24px; overflow: hidden; }
        .admin-card-header { background: var(--admin-primary); color: #fff; padding: 14px 20px; font-weight: 700; font-size: .9rem; }
        .admin-stat-card { background: #fff; border-radius: 10px; padding: 18px 20px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
        .stat-icon { width: 50px; height: 50px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .stat-label { font-size: .78rem; text-transform: uppercase; letter-spacing: .5px; color: #6c757d; font-weight: 600; }
        .stat-value { font-size: 1.8rem; font-weight: 800; color: #1a1a2e; line-height: 1.2; }
        .table { margin-bottom: 0; }
        .table thead th { font-size: .8rem; text-transform: uppercase; letter-spacing: .5px; font-weight: 700; padding: 12px 16px; }
        .table tbody td { padding: 12px 16px; vertical-align: middle; border-color: #f0f2f5; }
        .status-badge { padding: 4px 12px; border-radius: 20px; font-size: .78rem; font-weight: 700; text-transform: uppercase; display: inline-block; }
        .status-scheduled { background: #e3f2fd; color: #1565c0; }
        .status-boarding { background: #e8f5e9; color: #2e7d32; }
        .status-departed { background: #fff3e0; color: #e65100; }
        .status-delayed { background: #fff8e1; color: #f57f17; }
        .status-cancelled { background: #ffebee; color: #c62828; }
        .status-arrived { background: #e8f5e9; color: #1b5e20; }
        .admin-sidebar .lang-row { padding: 8px 20px; display: flex; gap: 8px; }
        .admin-sidebar .lang-row a { color: rgba(255,255,255,.6); text-decoration: none; font-size: .75rem; font-weight: 700; border: 1px solid rgba(255,255,255,.2); padding: 2px 8px; border-radius: 3px; }
        .admin-sidebar .lang-row a:hover, .admin-sidebar .lang-row a.active-lang { color: #d4a017; border-color: #d4a017; }
        .sidebar-divider { border-top: 1px solid rgba(255,255,255,.08); margin: 4px 0; }
    </style>
</head>
<body>
    <nav class="admin-sidebar">
        <div class="brand">
            <a asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-plane me-2"></i>Sky<span>Way</span> <small style="font-size:.65rem;opacity:.5;font-weight:400">Admin</small>
            </a>
        </div>

        <div class="nav-section mt-2">@L["Admin_General"]</div>
        <a asp-area="Admin" asp-controller="Home" asp-action="Index"
           class="nav-link @(ctrl == "Home" && (action == "Index" || action == "") ? "active" : "")">
            <i class="fas fa-tachometer-alt"></i> @L["Admin_Dashboard"]
        </a>

        <div class="nav-section">@L["Flight_Management"]</div>
        <a asp-area="Admin" asp-controller="Flight" asp-action="Index"
           class="nav-link @(ctrl == "Flight" ? "active" : "")">
            <i class="fas fa-plane-departure"></i> @L["Nav_Flights"]
        </a>
        <a asp-area="Admin" asp-controller="Route" asp-action="Index"
           class="nav-link @(ctrl == "Route" ? "active" : "")">
            <i class="fas fa-route"></i> @L["Route_Management"]
        </a>
        <a asp-area="Admin" asp-controller="Aircraft" asp-action="Index"
           class="nav-link @(ctrl == "Aircraft" ? "active" : "")">
            <i class="fas fa-helicopter"></i> @L["Aircraft_Management"]
        </a>
        <a asp-area="Admin" asp-controller="Airport" asp-action="Index"
           class="nav-link @(ctrl == "Airport" ? "active" : "")">
            <i class="fas fa-building"></i> @L["Airport_Management"]
        </a>

        <div class="nav-section">@L["Admin_Reservations"]</div>
        <a asp-area="Admin" asp-controller="Booking" asp-action="Index"
           class="nav-link @(ctrl == "Booking" ? "active" : "")">
            <i class="fas fa-ticket-alt"></i> @L["Booking_All"]
        </a>
        <a asp-area="Admin" asp-controller="User" asp-action="Index"
           class="nav-link @(ctrl == "User" ? "active" : "")">
            <i class="fas fa-users"></i> @L["Admin_Users"]
        </a>

        <div class="nav-section">@L["Admin_System"]</div>
        <a asp-area="Admin" asp-controller="Home" asp-action="Hangfire"
           class="nav-link @(action == "Hangfire" ? "active" : "")">
            <i class="fas fa-cogs"></i> @L["Admin_Hangfire"]
        </a>
        <a asp-area="Admin" asp-controller="Home" asp-action="Logs"
           class="nav-link @(action == "Logs" ? "active" : "")">
            <i class="fas fa-file-alt"></i> @L["Admin_Logs"]
        </a>
        <a asp-area="Admin" asp-controller="Home" asp-action="Notifications"
           class="nav-link @(action == "Notifications" ? "active" : "")">
            <i class="fas fa-bell"></i> @L["Admin_Notifications"]
        </a>

        <div class="sidebar-divider"></div>
        <div class="nav-section">@L["Nav_Language"]</div>
        <div class="lang-row">
            @{
                var adminLang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
            }
            <a asp-area="" asp-controller="Home" asp-action="SetLanguage"
               asp-route-lang="tr-TR" asp-route-returnUrl="@Context.Request.Path"
               class="@(adminLang == "tr" ? "active-lang" : "")">TR</a>
            <a asp-area="" asp-controller="Home" asp-action="SetLanguage"
               asp-route-lang="en-US" asp-route-returnUrl="@Context.Request.Path"
               class="@(adminLang == "en" ? "active-lang" : "")">EN</a>
        </div>

        <div class="nav-section">@L["Admin_AccountSection"]</div>
        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline w-100">
            @Html.AntiForgeryToken()
            <button type="submit" class="nav-link border-0 w-100 text-start" style="background:transparent">
                <i class="fas fa-sign-out-alt"></i> @L["Nav_Logout"]
            </button>
        </form>
    </nav>

    <div class="admin-content">
        <div class="admin-topbar">
            <h6 class="mb-0 fw-bold" style="color:#1a1a2e">@pageTitle</h6>
            <div class="d-flex align-items-center gap-3">
                <span class="badge" style="background:var(--admin-accent)"><i class="fas fa-user-shield me-1"></i>Admin</span>
                <span class="text-muted small">@Context.Session.GetString("UserName")</span>
            </div>
        </div>

        @await Component.InvokeAsync("Notyf")

        <div class="admin-body">
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
