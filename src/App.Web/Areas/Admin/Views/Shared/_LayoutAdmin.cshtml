@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString()    ?? "";
    var pageTitle = (ctrl, action) switch {
        ("Home", "Hangfire")      => L["Admin_Hangfire"].Value,
        ("Home", "Logs")          => L["Admin_Logs"].Value,
        ("Home", "Notifications") => L["Admin_Notifications"].Value,
        ("Home", _)               => L["Admin_Dashboard"].Value,
        ("Flight", "Create")      => L["Flight_Add"].Value,
        ("Flight", "Edit")        => L["Flight_Edit"].Value,
        ("Flight", "Detail")      => L["Flight_Detail"].Value,
        ("Flight", _)             => L["Flight_Management"].Value,
        ("Aircraft", "Create")    => L["Aircraft_Add"].Value,
        ("Aircraft", "Edit")      => L["Aircraft_Edit"].Value,
        ("Aircraft", "Detail")    => L["Aircraft_Detail"].Value,
        ("Aircraft", _)           => L["Aircraft_Management"].Value,
        ("Airport", "Create")     => L["Airport_Add"].Value,
        ("Airport", "Edit")       => L["Airport_Edit"].Value,
        ("Airport", "Detail")     => L["Airport_Detail"].Value,
        ("Airport", _)            => L["Airport_Management"].Value,
        ("Route", "Create")       => L["Route_Add"].Value,
        ("Route", "Edit")         => L["Route_Edit"].Value,
        ("Route", "Detail")       => L["Route_Detail"].Value,
        ("Route", _)              => L["Route_Management"].Value,
        ("Schedule", "Create")    => L["Schedule_Add"].Value,
        ("Schedule", "Edit")      => L["Schedule_Edit"].Value,
        ("Schedule", "Detail")    => L["Schedule_Detail"].Value,
        ("Schedule", _)           => L["Schedule_Management"].Value,
        ("Booking", "Detail")     => L["Booking_Detail"].Value,
        ("Booking", _)            => L["Booking_Management"].Value,
        ("User", "Detail")        => L["Admin_UserDetail"].Value,
        ("User", _)               => L["Admin_UserManagement"].Value,
        _                         => "SkyWay Admin"
    };
    var adminLang    = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var adminUser    = Context.Session.GetString("UserName") ?? "Admin";
    var returnUrl    = Context.Request.Path.ToString();
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle — SkyWay Admin</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body data-val-msg="@L["Error_Form_Invalid"]">

    <!-- ── Page loader ── -->
    <div id="pageLoader">
        <div class="loader-circle">
            <div class="loader-brand"><i class="fas fa-plane me-2"></i>Sky<span>Way</span></div>
            <div class="loader-runway">
                <div class="loader-bar"></div>
                <i class="fas fa-plane loader-plane-icon"></i>
            </div>
        </div>
    </div>

    <!-- ── Sidebar ── -->
    <aside class="admin-sidebar" id="adminSidebar">

        <div class="sidebar-brand">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="brand-link">
                <div class="brand-icon"><i class="fas fa-plane"></i></div>
                <div class="brand-text">Sky<span>Way</span> <em>Admin</em></div>
            </a>
        </div>

        <nav class="sidebar-nav">

            <div class="nav-group-label">@L["Admin_General"]</div>
            <a asp-area="Admin" asp-controller="Home" asp-action="Index"
               class="sidebar-link @(ctrl == "Home" && action is "Index" or "" ? "active" : "")">
                <i class="fas fa-tachometer-alt"></i>
                <span>@L["Admin_Dashboard"]</span>
            </a>

            <div class="nav-group-label">@L["Flight_Management"]</div>
            <a asp-area="Admin" asp-controller="Flight" asp-action="Index"
               class="sidebar-link @(ctrl == "Flight" ? "active" : "")">
                <i class="fas fa-plane-departure"></i>
                <span>@L["Nav_Flights"]</span>
            </a>
            <a asp-area="Admin" asp-controller="Schedule" asp-action="Index"
               class="sidebar-link @(ctrl == "Schedule" ? "active" : "")">
                <i class="fas fa-calendar-alt"></i>
                <span>@L["Schedule_Management"]</span>
            </a>
            <a asp-area="Admin" asp-controller="Route" asp-action="Index"
               class="sidebar-link @(ctrl == "Route" ? "active" : "")">
                <i class="fas fa-route"></i>
                <span>@L["Route_Management"]</span>
            </a>
            <a asp-area="Admin" asp-controller="Aircraft" asp-action="Index"
               class="sidebar-link @(ctrl == "Aircraft" ? "active" : "")">
                <i class="fas fa-helicopter"></i>
                <span>@L["Aircraft_Management"]</span>
            </a>
            <a asp-area="Admin" asp-controller="Airport" asp-action="Index"
               class="sidebar-link @(ctrl == "Airport" ? "active" : "")">
                <i class="fas fa-building"></i>
                <span>@L["Airport_Management"]</span>
            </a>

            <div class="nav-group-label">@L["Admin_Reservations"]</div>
            <a asp-area="Admin" asp-controller="Booking" asp-action="Index"
               class="sidebar-link @(ctrl == "Booking" ? "active" : "")">
                <i class="fas fa-ticket-alt"></i>
                <span>@L["Booking_All"]</span>
            </a>
            <a asp-area="Admin" asp-controller="User" asp-action="Index"
               class="sidebar-link @(ctrl == "User" ? "active" : "")">
                <i class="fas fa-users"></i>
                <span>@L["Admin_Users"]</span>
            </a>

            <div class="nav-group-label">@L["Admin_System"]</div>
            <a asp-area="Admin" asp-controller="Home" asp-action="Hangfire"
               class="sidebar-link @(action == "Hangfire" ? "active" : "")">
                <i class="fas fa-cogs"></i>
                <span>@L["Admin_Hangfire"]</span>
            </a>
            <a asp-area="Admin" asp-controller="Home" asp-action="Logs"
               class="sidebar-link @(action == "Logs" ? "active" : "")">
                <i class="fas fa-file-alt"></i>
                <span>@L["Admin_Logs"]</span>
            </a>
            <a asp-area="Admin" asp-controller="Home" asp-action="Notifications"
               class="sidebar-link @(action == "Notifications" ? "active" : "")">
                <i class="fas fa-bell"></i>
                <span>@L["Admin_Notifications"]</span>
            </a>

        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-footer-avatar"><i class="fas fa-user-shield"></i></div>
            <div class="sidebar-footer-info">
                <div class="sidebar-footer-name">@adminUser</div>
                <div class="sidebar-footer-role">Administrator</div>
            </div>
        </div>

    </aside>

    <!-- ── Overlay (mobile) ── -->
    <div class="admin-overlay" id="adminOverlay" onclick="closeSidebar()"></div>

    <!-- ── Main content ── -->
    <div class="admin-content" id="adminContent">

        <!-- Topbar -->
        <header class="admin-topbar">
            <div class="topbar-left">
                <button class="topbar-toggle" id="sidebarToggle" onclick="toggleSidebar()" aria-label="Toggle menu">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="topbar-breadcrumb">
                    <span class="topbar-page-title">@pageTitle</span>
                </div>
            </div>

            <div class="topbar-right">

                <!-- Language switcher -->
                <div class="lang-switcher" role="group" aria-label="Language">
                    <a asp-area="" asp-controller="Home" asp-action="SetLanguage"
                       asp-route-lang="tr-TR" asp-route-returnUrl="@returnUrl"
                       class="lang-btn @(adminLang == "tr" ? "lang-active" : "")"
                       title="Türkçe">TR</a>
                    <a asp-area="" asp-controller="Home" asp-action="SetLanguage"
                       asp-route-lang="en-US" asp-route-returnUrl="@returnUrl"
                       class="lang-btn @(adminLang == "en" ? "lang-active" : "")"
                       title="English">EN</a>
                </div>

                <!-- Notifications shortcut -->
                <a asp-area="Admin" asp-controller="Home" asp-action="Notifications"
                   class="topbar-icon-btn @(action == "Notifications" ? "active" : "")"
                   title="@L["Admin_Notifications"]">
                    <i class="fas fa-bell"></i>
                </a>

                <!-- User dropdown -->
                <div class="dropdown">
                    <button class="user-menu-btn dropdown-toggle" type="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="user-avatar-circle">
                            <i class="fas fa-user-shield"></i>
                        </div>
                        <div class="user-meta d-none d-md-block">
                            <span class="user-name-text">@adminUser</span>
                            <span class="user-role-text">Administrator</span>
                        </div>
                        <i class="fas fa-chevron-down chevron-icon d-none d-md-inline"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end user-dropdown">
                        <li class="dropdown-header-item">
                            <div class="dropdown-user-avatar"><i class="fas fa-user-shield"></i></div>
                            <div>
                                <div class="fw-bold">@adminUser</div>
                                <small class="text-muted">Administrator</small>
                            </div>
                        </li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                               class="dropdown-item">
                                <i class="fas fa-tachometer-alt me-2 text-primary"></i>@L["Admin_Dashboard"]
                            </a>
                        </li>
                        <li>
                            <a asp-area="Admin" asp-controller="Home" asp-action="Notifications"
                               class="dropdown-item">
                                <i class="fas fa-bell me-2 text-warning"></i>@L["Admin_Notifications"]
                            </a>
                        </li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <form asp-area="" asp-controller="Account" asp-action="SignOut" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt me-2"></i>@L["Nav_SignOut"]
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>

            </div>
        </header>

        <!-- Toast notifications -->
        @{
            var _swToasts = TempData["_sw_toasts"] as string;
        }
        @if (!string.IsNullOrEmpty(_swToasts))
        {
            <div id="sw-toast-stack" class="position-fixed end-0 p-3"
                 style="top:72px;z-index:1055;min-width:320px;max-width:440px"
                 data-toasts="@_swToasts"></div>
        }

        <!-- Page body -->
        <main class="admin-body">
            @RenderBody()
        </main>

    </div>

    <!-- Confirm modal (shared, wired by admin.js) -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle text-danger me-2"></i>@L["Btn_Confirm"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="confirmModalBody"></div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L["Btn_Cancel"]</button>
                    <button type="button" class="btn btn-danger" id="confirmModalOk">@L["Btn_Confirm"]</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    <script src="~/js/sw-toast.js" asp-append-version="true"></script>
    <script>
    var _sidebarCollapsed = false;

    function toggleSidebar() {
        if (window.innerWidth < 992) {
            document.getElementById('adminSidebar').classList.toggle('sidebar-open');
            document.getElementById('adminOverlay').classList.toggle('show');
        } else {
            _sidebarCollapsed = !_sidebarCollapsed;
            document.getElementById('adminSidebar').classList.toggle('sidebar-collapsed', _sidebarCollapsed);
            document.getElementById('adminContent').classList.toggle('content-expanded', _sidebarCollapsed);
        }
    }

    function closeSidebar() {
        document.getElementById('adminSidebar').classList.remove('sidebar-open');
        document.getElementById('adminOverlay').classList.remove('show');
    }

    window.addEventListener('resize', function () {
        if (window.innerWidth >= 992) closeSidebar();
    });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
