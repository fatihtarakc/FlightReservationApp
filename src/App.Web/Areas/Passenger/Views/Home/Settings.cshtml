@model PassengerSettingsPageVM

<ul class="nav nav-tabs mb-4" id="settingsTabs">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#profileTab">
            <i class="fas fa-user me-1"></i> @L["Account_ProfileInfo"]
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#passwordTab">
            <i class="fas fa-lock me-1"></i> @L["Account_ChangePassword"]
        </button>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="profileTab">
        <div class="pax-card">
            <div class="pax-card-header"><i class="fas fa-user me-2"></i>@L["Account_ProfileInfo"]</div>
            <div class="p-4">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="mb-2"><span class="fw-semibold text-muted small">@L["Account_Name"]:</span> @Model.Profile.Name</div>
                        <div class="mb-2"><span class="fw-semibold text-muted small">@L["Account_Surname"]:</span> @Model.Profile.Surname</div>
                        <div class="mb-2"><span class="fw-semibold text-muted small">@L["Account_Username"]:</span> @Model.Profile.UserName</div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-2"><span class="fw-semibold text-muted small">@L["Account_Email"]:</span> @Model.Profile.Email</div>
                        <div class="mb-2"><span class="fw-semibold text-muted small">@L["Account_Phone"]:</span> @Model.Profile.PhoneNumber</div>
                        <div class="mb-2"><span class="fw-semibold text-muted small">@L["Account_BirthDate"]:</span> @Model.Profile.BirthDate.ToString("dd.MM.yyyy")</div>
                    </div>
                </div>

                <form asp-area="Passenger" asp-controller="Home" asp-action="UpdateProfile" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">@L["Account_Name"]</label>
                            <input asp-for="UpdateForm.Name" class="form-control" required/>
                            <span asp-validation-for="UpdateForm.Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">@L["Account_Surname"]</label>
                            <input asp-for="UpdateForm.Surname" class="form-control" required/>
                            <span asp-validation-for="UpdateForm.Surname" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">@L["Account_Email"]</label>
                            <input asp-for="UpdateForm.Email" class="form-control" type="email" required readonly/>
                            <span asp-validation-for="UpdateForm.Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">@L["Account_Phone"]</label>
                            <div class="input-group">
                                <div class="dropdown">
                                    <button type="button" class="btn btn-outline-secondary dropdown-toggle px-2"
                                            id="settingsCountryDropBtn" data-bs-toggle="dropdown" aria-expanded="false"
                                            style="min-width:88px;border-top-right-radius:0;border-bottom-right-radius:0">
                                        <span id="settingsSelectedFlag">🇹🇷</span>
                                        <span id="settingsSelectedCode" class="ms-1">+90</span>
                                    </button>
                                    <ul class="dropdown-menu p-0" id="settingsCountryList"
                                        style="max-height:220px;overflow-y:auto;min-width:240px">
                                        <li class="px-2 pt-2 pb-1 sticky-top bg-white border-bottom">
                                            <input type="text" class="form-control form-control-sm"
                                                   id="settingsCountrySearch" autocomplete="off"
                                                   placeholder="@L["Placeholder_Search"]" />
                                        </li>
                                    </ul>
                                </div>
                                <input type="text" id="settingsPhoneLocal" class="form-control"
                                       maxlength="10" placeholder="5XXXXXXXXX" inputmode="numeric" />
                                <input type="hidden" asp-for="UpdateForm.PhoneNumber" id="settingsFullPhone" />
                            </div>
                            <span asp-validation-for="UpdateForm.PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            @{
                                var pref = Model.UpdateForm.NotificationPreference;
                                var effective = pref.HasFlag(NotificationChannel.Email)  ? NotificationChannel.Email
                                             : pref.HasFlag(NotificationChannel.Sms)    ? NotificationChannel.Sms
                                             : NotificationChannel.WhatsApp;
                            }
                            <label class="form-label fw-semibold text-muted small text-uppercase">@L["Account_Notification"]</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input notif-check" type="radio" name="UpdateForm.NotificationPreference"
                                           value="@((int)NotificationChannel.Email)" id="notifEmail"
                                           @(effective == NotificationChannel.Email ? "checked" : "") />
                                    <label class="form-check-label" for="notifEmail"><i class="fas fa-envelope me-1"></i>@L["Notif_Email"]</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input notif-check" type="radio" name="UpdateForm.NotificationPreference"
                                           value="@((int)NotificationChannel.Sms)" id="notifSms"
                                           @(effective == NotificationChannel.Sms ? "checked" : "") />
                                    <label class="form-check-label" for="notifSms"><i class="fas fa-comment-sms me-1"></i>@L["Notif_Sms"]</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input notif-check" type="radio" name="UpdateForm.NotificationPreference"
                                           value="@((int)NotificationChannel.WhatsApp)" id="notifWhatsApp"
                                           @(effective == NotificationChannel.WhatsApp ? "checked" : "") />
                                    <label class="form-check-label" for="notifWhatsApp"><i class="fab fa-whatsapp me-1"></i>@L["Notif_WhatsApp"]</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-danger mt-3">
                        <i class="fas fa-save me-1"></i> @L["Btn_Save"]
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="passwordTab">
        <div class="pax-card">
            <div class="pax-card-header"><i class="fas fa-lock me-2"></i>@L["Account_ChangePassword"]</div>
            <div class="p-4">
                <form asp-area="Passenger" asp-controller="Home" asp-action="ChangePassword" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="row g-3" style="max-width:480px">
                        <div class="col-12">
                            <label class="form-label fw-semibold">@L["Account_CurrentPassword"]</label>
                            <div class="input-group">
                                <input asp-for="PasswordForm.CurrentPassword" type="password" class="form-control" id="pwdCurrent" required/>
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('pwdCurrent',this)"><i class="fas fa-eye"></i></button>
                            </div>
                            <span asp-validation-for="PasswordForm.CurrentPassword" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">@L["Account_Password"]</label>
                            <div class="input-group">
                                <input asp-for="PasswordForm.NewPassword" type="password" class="form-control" id="pwdNew" required/>
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('pwdNew',this)"><i class="fas fa-eye"></i></button>
                            </div>
                            <div class="progress mt-1" style="height:4px">
                                <div id="pwStrength" class="progress-bar" style="width:0%"></div>
                            </div>
                            <span asp-validation-for="PasswordForm.NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">@L["Account_ConfirmPassword"]</label>
                            <div class="input-group">
                                <input asp-for="PasswordForm.ConfirmPassword" type="password" class="form-control" id="pwdConfirm" required/>
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('pwdConfirm',this)"><i class="fas fa-eye"></i></button>
                            </div>
                            <span asp-validation-for="PasswordForm.ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-danger mt-3">
                        <i class="fas fa-key me-1"></i> @L["Account_UpdatePassword"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-form-validation.js"></script>
    <script src="~/js/signup.js" asp-append-version="true"></script>
    <script>
    (function () {
        'use strict';

        var settingsCountryCode = '+90';
        var pageLang = document.documentElement.lang || 'tr';

        function cName(c) {
            return pageLang === 'en' ? (c.nameEn || '') : (c.nameTr || '');
        }

        function renderSettingsCountries(list) {
            var $ul = $('#settingsCountryList');
            $ul.find('li:not(:first-child)').remove();
            list.forEach(function (c) {
                var name = cName(c);
                var li = $('<li></li>');
                var a = $('<a class="dropdown-item py-2" href="#"></a>')
                    .html('<span class="me-2">' + c.flag + '</span><span>' + name + '</span>' +
                          '<span class="float-end text-muted small">' + c.code + '</span>')
                    .on('click', function (e) {
                        e.preventDefault();
                        settingsCountryCode = c.code;
                        $('#settingsSelectedFlag').text(c.flag);
                        $('#settingsSelectedCode').text(c.code);
                        updateSettingsPhone();
                        $('#settingsCountryDropBtn').dropdown('hide');
                    });
                li.append(a);
                $ul.append(li);
            });
        }

        function updateSettingsPhone() {
            var num = $('#settingsPhoneLocal').val().replace(/\D/g, '');
            $('#settingsFullPhone').val(num ? settingsCountryCode + num : '');
        }

        function prePopulate() {
            var existing = $('#settingsFullPhone').val();
            if (!existing) return;
            var sorted = countries.slice().sort(function (a, b) { return b.code.length - a.code.length; });
            var matched = sorted.find(function (c) { return existing.startsWith(c.code); });
            if (matched) {
                settingsCountryCode = matched.code;
                $('#settingsSelectedFlag').text(matched.flag);
                $('#settingsSelectedCode').text(matched.code);
                $('#settingsPhoneLocal').val(existing.slice(matched.code.length));
            }
        }

        $(document).ready(function () {
            if (!document.getElementById('settingsPhoneLocal')) return;

            renderSettingsCountries(countries);
            prePopulate();

            $('#settingsCountrySearch').on('input', function () {
                var q = $(this).val().toLowerCase();
                renderSettingsCountries(countries.filter(function (c) {
                    return cName(c).toLowerCase().includes(q) || c.code.includes(q);
                }));
            });

            $('#settingsPhoneLocal').on('input', function () {
                $(this).val($(this).val().replace(/\D/g, '').slice(0, 10));
                $(this).removeClass('is-invalid');
                $('span[data-valmsg-for="UpdateForm.PhoneNumber"]').text('');
                updateSettingsPhone();
            });

            $('#settingsPhoneLocal').closest('form').on('submit', function (e) {
                var local = $('#settingsPhoneLocal').val().replace(/\D/g, '');
                var $span = $('span[data-valmsg-for="UpdateForm.PhoneNumber"]');
                if (local.length !== 10) {
                    e.preventDefault();
                    $('#settingsPhoneLocal').addClass('is-invalid');
                    $span.text(pageLang === 'en'
                        ? 'Please enter a 10-digit phone number.'
                        : 'Lütfen 10 haneli telefon numarası giriniz.');
                } else {
                    updateSettingsPhone();
                }
            });
        });
    })();
    </script>
}
