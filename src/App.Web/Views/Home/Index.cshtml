@model HomePageVM

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <p class="text-uppercase mb-2" style="color:var(--gold);letter-spacing:2px;font-weight:600;font-size:.85rem">@L["Home_TrustedAirline"]</p>
                <h1 class="display-4 fw-bold mb-3">@L["Home_HeroHeading"] <span style="color:var(--gold)">@L["Home_HeroHeadingAccent"]</span></h1>
                <p class="lead mb-4" style="color:rgba(255,255,255,.8)">@L["Home_HeroDescription"]</p>
                <div class="d-flex gap-3">
                    <a asp-controller="Flight" asp-action="Index" class="btn btn-book px-4 py-3">
                        <i class="fas fa-search me-2"></i>@L["Flight_Search"]
                    </a>
                    <a asp-controller="Home" asp-action="About" class="btn btn-outline-light px-4 py-3">
                        @L["Nav_About"]
                    </a>
                </div>
                <div class="row mt-5">
                    <div class="col-4 text-center">
                        <h3 class="fw-bold mb-0" style="color:var(--gold)">50+</h3>
                        <small style="color:rgba(255,255,255,.7)">@L["Home_StatDestinations"]</small>
                    </div>
                    <div class="col-4 text-center">
                        <h3 class="fw-bold mb-0" style="color:var(--gold)">1M+</h3>
                        <small style="color:rgba(255,255,255,.7)">@L["Home_StatPassengers"]</small>
                    </div>
                    <div class="col-4 text-center">
                        <h3 class="fw-bold mb-0" style="color:var(--gold)">99%</h3>
                        <small style="color:rgba(255,255,255,.7)">@L["Home_StatSatisfaction"]</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="search-box">
                    <h5 class="fw-bold mb-4" style="color:var(--secondary)"><i class="fas fa-plane me-2" style="color:var(--primary)"></i>@L["Flight_Search"]</h5>
                    <form asp-controller="Flight" asp-action="Index" method="get" id="searchForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">@L["Flight_Departure"]</label>
                                <button type="button" id="departurePicker" class="airport-toggle-btn"
                                        data-placeholder="@L["Label_SelectOption"]">
                                    <span id="departureText" class="airport-placeholder">@L["Label_SelectOption"]</span>
                                    <i class="fas fa-chevron-down"></i>
                                </button>
                                <input type="hidden" name="DepartureIata" id="departureIataInput">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@L["Flight_Arrival"]</label>
                                <button type="button" id="arrivalPicker" class="airport-toggle-btn"
                                        data-placeholder="@L["Label_SelectOption"]">
                                    <span id="arrivalText" class="airport-placeholder">@L["Label_SelectOption"]</span>
                                    <i class="fas fa-chevron-down"></i>
                                </button>
                                <input type="hidden" name="ArrivalIata" id="arrivalIataInput">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@L["Flight_Date"]</label>
                                <input type="date" name="DepartureDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@L["Label_CabinAndPassenger"]</label>
                                <div id="passengerPicker"
                                     data-label-passenger="@L["Label_Passenger"]"
                                     data-label-economy="@L["Flight_Economy"]"
                                     data-label-business="@L["Flight_Business"]">
                                    <button type="button" id="passengerToggle" class="pax-toggle-btn">
                                        <span id="passengerSummary">1 @L["Label_Passenger"] · @L["Flight_Economy"]</span>
                                        <i class="fas fa-chevron-down"></i>
                                    </button>
                                    <input type="hidden" name="Passengers" id="passengersInput" value="1">
                                    <input type="hidden" name="SeatClass" id="seatClassInput" value="1">
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-search">
                                    <i class="fas fa-search me-2"></i>@L["Flight_Search"]
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Routes Section -->
@if (Model.PopularRoutes.Any())
{
    <section class="py-5">
        <div class="container">
            <div class="text-center mb-5">
                <p class="text-uppercase mb-2" style="color:var(--primary);letter-spacing:2px;font-size:.8rem;font-weight:700">@L["Home_PopularRoutes"]</p>
                <h2 class="fw-bold" style="color:var(--secondary)">@L["Home_DiscoverDestinations"]</h2>
            </div>
            <div class="row g-4">
                @foreach (var route in Model.PopularRoutes)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="card border-0 shadow-sm h-100" style="border-radius:12px;overflow:hidden;transition:transform .3s" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                            <div style="background:linear-gradient(135deg,var(--secondary),var(--primary));height:140px;display:flex;align-items:center;justify-content:center;padding:20px">
                                <div class="text-center text-white">
                                    <div class="d-flex align-items-center justify-content-center gap-3">
                                        <div>
                                            <div style="font-size:1.4rem;font-weight:800">@route.OriginIata</div>
                                            <small style="opacity:.8">@route.OriginCity</small>
                                        </div>
                                        <i class="fas fa-plane" style="font-size:1.2rem;opacity:.7"></i>
                                        <div>
                                            <div style="font-size:1.4rem;font-weight:800">@route.DestinationIata</div>
                                            <small style="opacity:.8">@route.DestinationCity</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted small"><i class="fas fa-clock me-1"></i>@(route.DurationMinutes / 60) @L["Label_HourAbbr"] @(route.DurationMinutes % 60) @L["Label_MinAbbr"]</span>
                                    <span class="text-muted small"><i class="fas fa-ruler-horizontal me-1"></i>@route.DistanceKm.ToString("N0") km</span>
                                </div>
                                <a asp-controller="Flight" asp-action="Index" asp-route-DepartureIata="@route.OriginIata" asp-route-ArrivalIata="@route.DestinationIata" asp-route-DepartureDate="@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-sm w-100" style="background:var(--primary);color:#fff;font-weight:700">
                                    @L["Home_FindFlight"]
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Recent Flights -->
@if (Model.RecentFlights.Any())
{
    <section class="py-5 bg-light">
        <div class="container">
            <div class="text-center mb-5">
                <p class="text-uppercase mb-2" style="color:var(--primary);letter-spacing:2px;font-size:.8rem;font-weight:700">@L["Home_CurrentFlights"]</p>
                <h2 class="fw-bold" style="color:var(--secondary)">@L["Home_RecentFlights"]</h2>
            </div>
            <div class="row g-3">
                @foreach (var flight in Model.RecentFlights)
                {
                    <div class="col-lg-6">
                        <div class="flight-card">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="flight-number">@flight.FlightNumber</span>
                                    <span class="ms-2 text-muted small">@flight.AircraftModel</span>
                                </div>
                                @{
                                    var statusClass = flight.Status switch {
                                        FlightStatus.Scheduled => "status-scheduled",
                                        FlightStatus.Boarding => "status-boarding",
                                        FlightStatus.Departed => "status-departed",
                                        FlightStatus.Delayed => "status-delayed",
                                        FlightStatus.Cancelled => "status-cancelled",
                                        FlightStatus.Arrived => "status-arrived",
                                        _ => "status-scheduled"
                                    };
                                }
                                <span class="status-badge @statusClass">@L["Status_" + flight.Status.ToString()]</span>
                            </div>
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="text-center">
                                    <div class="fw-bold fs-5">@flight.DepartureTime.ToString("HH:mm")</div>
                                    <div class="fw-bold" style="color:var(--primary)">@flight.OriginIata</div>
                                    <small class="text-muted">@flight.OriginCity</small>
                                </div>
                                <div class="text-center flex-grow-1 px-3">
                                    <small class="text-muted d-block">@flight.DurationFormatted</small>
                                    <div class="d-flex align-items-center">
                                        <div style="height:2px;flex-grow:1;background:#dee2e6"></div>
                                        <i class="fas fa-plane mx-2 text-muted" style="font-size:.75rem"></i>
                                        <div style="height:2px;flex-grow:1;background:#dee2e6"></div>
                                    </div>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold fs-5">@flight.ArrivalTime.ToString("HH:mm")</div>
                                    <div class="fw-bold" style="color:var(--primary)">@flight.DestinationIata</div>
                                    <small class="text-muted">@flight.DestinationCity</small>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                <span class="price-badge">₺@flight.EconomyPrice.ToString("N0")</span>
                                <a asp-controller="Flight" asp-action="Detail" asp-route-id="@flight.Id" class="btn btn-sm" style="border:2px solid var(--primary);color:var(--primary);font-weight:700">
                                    @L["Flight_SelectSeat"] <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a asp-controller="Flight" asp-action="Index" class="btn btn-book px-5 py-3">
                    @L["Home_ViewAllFlights"] <i class="fas fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </section>
}

<!-- Features -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3 text-center">
                <div class="p-4">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;background:rgba(200,16,46,.1)">
                        <i class="fas fa-shield-alt fa-2x" style="color:var(--primary)"></i>
                    </div>
                    <h5 class="fw-bold" style="color:var(--secondary)">@L["Feature_SafeFlight"]</h5>
                    <p class="text-muted small">@L["Feature_SafeFlight_Desc"]</p>
                </div>
            </div>
            <div class="col-md-3 text-center">
                <div class="p-4">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;background:rgba(200,16,46,.1)">
                        <i class="fas fa-tag fa-2x" style="color:var(--primary)"></i>
                    </div>
                    <h5 class="fw-bold" style="color:var(--secondary)">@L["Feature_AffordablePrice"]</h5>
                    <p class="text-muted small">@L["Feature_AffordablePrice_Desc"]</p>
                </div>
            </div>
            <div class="col-md-3 text-center">
                <div class="p-4">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;background:rgba(200,16,46,.1)">
                        <i class="fas fa-headset fa-2x" style="color:var(--primary)"></i>
                    </div>
                    <h5 class="fw-bold" style="color:var(--secondary)">@L["Feature_Support"]</h5>
                    <p class="text-muted small">@L["Feature_Support_Desc"]</p>
                </div>
            </div>
            <div class="col-md-3 text-center">
                <div class="p-4">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;background:rgba(200,16,46,.1)">
                        <i class="fas fa-mobile-alt fa-2x" style="color:var(--primary)"></i>
                    </div>
                    <h5 class="fw-bold" style="color:var(--secondary)">@L["Feature_Online"]</h5>
                    <p class="text-muted small">@L["Feature_Online_Desc"]</p>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="passengerPanel" class="pax-panel" style="display:none">
    <div class="pax-cabin-row">
        <div class="pax-cabin-opt active" data-cabin="1">@L["Flight_Economy"]</div>
        <div class="pax-cabin-opt" data-cabin="3">@L["Flight_Business"]</div>
    </div>
    <div class="pax-row-item">
        <div class="pax-label"><strong>@L["Flight_Passengers"]</strong></div>
        <div class="pax-counter">
            <button type="button" class="pax-btn" id="paxMinus">−</button>
            <span class="pax-num" id="passengerCount">1</span>
            <button type="button" class="pax-btn" id="paxPlus">+</button>
        </div>
    </div>
    <button type="button" id="passengerConfirm" class="pax-confirm-btn">@L["Btn_Ok"]</button>
</div>

<div id="airportPanel" class="airport-panel" style="display:none">
    <div class="airport-panel-header">
        <button type="button" id="airportPanelClose" class="airport-panel-close" aria-label="close">&times;</button>
    </div>
    <div class="airport-panel-body">
        <div id="countryList" class="country-list"></div>
        <div id="airportList" class="airport-list"></div>
    </div>
</div>

@section Scripts {
<script src="~/js/airport-picker.js" asp-append-version="true"></script>
<script src="~/js/home-search.js" asp-append-version="true"></script>
}

