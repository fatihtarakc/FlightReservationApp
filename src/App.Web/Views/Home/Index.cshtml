@{
    ViewData["Title"] = "Home";
    var upcoming = ViewBag.UpcomingFlights as List<FlightListItemViewModel> ?? new();
}

@section Scripts {
<script>
const AIRPORTS = [
    { iata:'IST', city:'Istanbul',  name:'Istanbul Airport',  flag:'🇹🇷' },
    { iata:'SAW', city:'Istanbul',  name:'Sabiha Gökçen',     flag:'🇹🇷' },
    { iata:'ESB', city:'Ankara',    name:'Esenboğa',          flag:'🇹🇷' },
    { iata:'ADB', city:'İzmir',     name:'Adnan Menderes',    flag:'🇹🇷' },
    { iata:'AYT', city:'Antalya',   name:'Antalya Airport',   flag:'🇹🇷' },
    { iata:'LHR', city:'London',    name:'Heathrow',          flag:'🇬🇧' },
    { iata:'DXB', city:'Dubai',     name:'International',     flag:'🇦🇪' },
    { iata:'JFK', city:'New York',  name:'JFK',               flag:'🇺🇸' },
    { iata:'FRA', city:'Frankfurt', name:'Frankfurt Airport', flag:'🇩🇪' },
    { iata:'CDG', city:'Paris',     name:'Charles de Gaulle', flag:'🇫🇷' },
];

function populateSelect(selId, excludeIata) {
    const sel = document.getElementById(selId);
    const current = sel.value;
    sel.innerHTML = '<option value="">Select airport...</option>';
    AIRPORTS.filter(a => a.iata !== excludeIata).forEach(a => {
        const opt = document.createElement('option');
        opt.value = a.iata;
        opt.textContent = a.flag + ' ' + a.city + ' — ' + a.name;
        if (a.iata === current) opt.selected = true;
        sel.appendChild(opt);
    });
}

document.addEventListener('DOMContentLoaded', function() {
    const depSel = document.getElementById('DepartureIata');
    const arrSel = document.getElementById('ArrivalIata');
    depSel.value = 'IST';
    populateSelect('DepartureIata', arrSel.value);
    populateSelect('ArrivalIata', depSel.value);
    depSel.addEventListener('change', () => populateSelect('ArrivalIata', depSel.value));
    arrSel.addEventListener('change', () => populateSelect('DepartureIata', arrSel.value));
});
</script>
}

<!-- Hero -->
<div class="rounded-4 text-white py-5 px-4 mb-4" style="background:linear-gradient(135deg,#0f3460 0%,#16213e 60%,#1a1a2e 100%)">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h1 class="display-5 fw-bold mb-2">
                <i class="bi bi-airplane-fill me-2"></i>Fly Anywhere
            </h1>
            <p class="lead opacity-75 mb-0">
                Search and book flights to hundreds of destinations worldwide with the best prices.
            </p>
        </div>
    </div>
</div>

<!-- Quick Search -->
<div class="card border-0 shadow mb-4">
    <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-search me-2 text-primary"></i>Quick Search</h5>
        <form asp-controller="Flight" asp-action="Search" method="post">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-sm-6 col-lg-3">
                    <label class="form-label fw-semibold">From</label>
                    <select id="DepartureIata" name="DepartureIata" class="form-select" required>
                        <option value="">Select airport...</option>
                    </select>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <label class="form-label fw-semibold">To</label>
                    <select id="ArrivalIata" name="ArrivalIata" class="form-select" required>
                        <option value="">Select airport...</option>
                    </select>
                </div>
                <div class="col-6 col-sm-4 col-lg-2">
                    <label class="form-label fw-semibold">Date</label>
                    <input type="date" name="DepartureDate" class="form-control"
                           value="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="col-3 col-sm-4 col-lg-1">
                    <label class="form-label fw-semibold">Pax</label>
                    <select name="Passengers" class="form-select">
                        @for (int i = 1; i <= 9; i++) { <option value="@i">@i</option> }
                    </select>
                </div>
                <div class="col-9 col-sm-6 col-lg-2">
                    <label class="form-label fw-semibold">Class</label>
                    <select name="SeatClass" class="form-select">
                        <option value="0">Economy</option>
                        <option value="1">Premium Economy</option>
                        <option value="2">Business</option>
                        <option value="3">First Class</option>
                    </select>
                </div>
                <div class="col-12 col-lg-1">
                    <button type="submit" class="btn btn-primary w-100 fw-semibold">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Upcoming Flights -->
<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-airplane-fill me-2 text-primary"></i>Upcoming Flights</h5>
        <a asp-controller="Flight" asp-action="Search" class="btn btn-outline-primary btn-sm">View all →</a>
    </div>

    @if (!upcoming.Any())
    {
        <div class="text-center py-4 text-muted">
            <i class="bi bi-airplane display-4 opacity-25"></i>
            <p class="mt-2">No upcoming flights available at the moment.</p>
        </div>
    }
    else
    {
        @foreach (var flight in upcoming)
        {
            <div class="card shadow-sm border-0 mb-3 flight-card">
                <div class="card-body p-3">
                    <div class="row align-items-center g-2">
                        <div class="col-12 col-md-3">
                            <div class="fw-bold text-primary">@flight.AirlineName</div>
                            <div class="text-muted small">Flight @flight.Number</div>
                        </div>
                        <div class="col-12 col-md-5">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="text-center">
                                    <div class="fw-bold fs-6">@flight.DepartureDateTime.ToString("HH:mm")</div>
                                    <div class="fw-semibold small">@flight.DepartureCity</div>
                                    <div class="text-muted small">@flight.DepartureDateTime.ToString("dd MMM")</div>
                                </div>
                                <div class="text-center flex-grow-1 px-2">
                                    <div class="text-muted small">@((flight.ArrivalDateTime - flight.DepartureDateTime).ToString(@"h\h\ mm\m"))</div>
                                    <div class="d-flex align-items-center">
                                        <div class="border-top flex-grow-1"></div>
                                        <i class="bi bi-airplane-fill text-primary mx-2 small"></i>
                                        <div class="border-top flex-grow-1"></div>
                                    </div>
                                    <div class="text-muted small">Direct</div>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold fs-6">@flight.ArrivalDateTime.ToString("HH:mm")</div>
                                    <div class="fw-semibold small">@flight.ArrivalCity</div>
                                    <div class="text-muted small">@flight.ArrivalDateTime.ToString("dd MMM")</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-2 text-center">
                            <div class="fw-bold text-success">@flight.BaseEconomyPrice.ToString("N0") @flight.Currency</div>
                            <div class="text-muted small">from / person</div>
                            @if (flight.AvailableSeats is > 0 and <= 5)
                            {
                                <span class="badge bg-warning text-dark small">@flight.AvailableSeats left!</span>
                            }
                        </div>
                        <div class="col-6 col-md-2 text-end">
                            <a asp-controller="Flight" asp-action="Book" asp-route-flightId="@flight.Id"
                               class="btn btn-primary btn-sm w-100">Select →</a>
                            <a asp-controller="Flight" asp-action="Details" asp-route-id="@flight.Id"
                               class="btn btn-link btn-sm text-muted p-0 mt-1 d-block">Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Feature Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4">
            <i class="bi bi-shield-check text-success display-5 mb-3"></i>
            <h6 class="fw-bold">Secure Booking</h6>
            <p class="text-muted mb-0 small">End-to-end encrypted bookings with instant PNR generation.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4">
            <i class="bi bi-bell text-warning display-5 mb-3"></i>
            <h6 class="fw-bold">Flight Reminders</h6>
            <p class="text-muted mb-0 small">Automatic alerts 7 days and 24 hours before departure.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4">
            <i class="bi bi-globe text-info display-5 mb-3"></i>
            <h6 class="fw-bold">Global Coverage</h6>
            <p class="text-muted mb-0 small">Hundreds of routes with competitive pricing and multiple classes.</p>
        </div>
    </div>
</div>
