@{
    ViewData["Title"] = "Hakkımızda - SkyWay Airlines";
}

<section class="py-5" style="background:linear-gradient(135deg,var(--secondary),#0f3460);color:#fff">
    <div class="container py-5 text-center">
        <h1 class="display-5 fw-bold mb-3">SkyWay Airlines Hakkında</h1>
        <p class="lead" style="color:rgba(255,255,255,.8)">Türkiye'nin güvenilir havayolu, 2010'dan beri hizmetinizde</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="text-uppercase mb-2" style="color:var(--primary);letter-spacing:2px;font-size:.8rem;font-weight:700">Misyonumuz</p>
                <h2 class="fw-bold mb-4" style="color:var(--secondary)">Uçuşun Keyfini Herkes İçin Erişilebilir Kılmak</h2>
                <p class="text-muted">SkyWay Airlines olarak, yolcularımıza güvenli, konforlu ve uygun fiyatlı uçuş deneyimi sunmayı amaçlıyoruz.</p>
                <p class="text-muted">Yıllar boyunca sürdürdüğümüz yüksek güvenlik standartları ve müşteri memnuniyeti odaklı hizmet anlayışımızla sektörün en güvenilir havayolları arasında yer alıyoruz.</p>
                <div class="row g-3 mt-3">
                    <div class="col-6">
                        <div class="p-3 rounded" style="background:#f8f9fa;border-left:4px solid var(--primary)">
                            <h4 class="fw-bold mb-0" style="color:var(--primary)">50+</h4>
                            <small class="text-muted">Destinasyon</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded" style="background:#f8f9fa;border-left:4px solid var(--primary)">
                            <h4 class="fw-bold mb-0" style="color:var(--primary)">1M+</h4>
                            <small class="text-muted">Mutlu Yolcu</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded" style="background:#f8f9fa;border-left:4px solid var(--primary)">
                            <h4 class="fw-bold mb-0" style="color:var(--primary)">15+</h4>
                            <small class="text-muted">Yıl Tecrübe</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded" style="background:#f8f9fa;border-left:4px solid var(--primary)">
                            <h4 class="fw-bold mb-0" style="color:var(--primary)">24/7</h4>
                            <small class="text-muted">Müşteri Desteği</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-12">
                        <div class="p-4 rounded-3 shadow-sm" style="background:var(--secondary);color:#fff">
                            <i class="fas fa-shield-alt fa-2x mb-3" style="color:var(--gold)"></i>
                            <h5 class="fw-bold">Güvenlik Önce</h5>
                            <p class="mb-0" style="color:rgba(255,255,255,.7);font-size:.9rem">Uluslararası güvenlik standartlarına tam uyum. Her uçuş öncesi kapsamlı teknik kontrol.</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-3 shadow-sm h-100" style="background:var(--primary);color:#fff">
                            <i class="fas fa-leaf fa-2x mb-2"></i>
                            <h6 class="fw-bold">Çevre Dostu</h6>
                            <p class="mb-0" style="font-size:.85rem;opacity:.85">Karbon ayak izimizi azaltmak için çalışıyoruz.</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-3 shadow-sm h-100" style="background:var(--gold);color:#000">
                            <i class="fas fa-award fa-2x mb-2"></i>
                            <h6 class="fw-bold">Ödüllü Hizmet</h6>
                            <p class="mb-0" style="font-size:.85rem;opacity:.85">Sektörde tanınan ve ödüllendirilen kalite.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
