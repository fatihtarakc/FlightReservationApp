<section class="py-5" style="background:linear-gradient(135deg,var(--secondary),#0f3460);color:#fff">
    <div class="container py-5 text-center">
        <h1 class="display-5 fw-bold mb-3">@L["About_Title"]</h1>
        <p class="lead" style="color:rgba(255,255,255,.8)">@L["About_Subtitle"]</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="text-uppercase mb-2" style="color:var(--primary);letter-spacing:2px;font-size:.8rem;font-weight:700">@L["About_Mission"]</p>
                <h2 class="fw-bold mb-4" style="color:var(--secondary)">@L["About_MissionTitle"]</h2>
                <p class="text-muted">@L["About_MissionText1"]</p>
                <p class="text-muted">@L["About_MissionText2"]</p>
                <div class="row g-3 mt-3">
                    <div class="col-6">
                        <div class="p-3 rounded" style="background:#f8f9fa;border-left:4px solid var(--primary)">
                            <h4 class="fw-bold mb-0" style="color:var(--primary)">50+</h4>
                            <small class="text-muted">@L["About_StatDestinations"]</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded" style="background:#f8f9fa;border-left:4px solid var(--primary)">
                            <h4 class="fw-bold mb-0" style="color:var(--primary)">1M+</h4>
                            <small class="text-muted">@L["About_StatPassengers"]</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded" style="background:#f8f9fa;border-left:4px solid var(--primary)">
                            <h4 class="fw-bold mb-0" style="color:var(--primary)">15+</h4>
                            <small class="text-muted">@L["About_StatYears"]</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded" style="background:#f8f9fa;border-left:4px solid var(--primary)">
                            <h4 class="fw-bold mb-0" style="color:var(--primary)">24/7</h4>
                            <small class="text-muted">@L["About_StatSupport"]</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-12">
                        <div class="p-4 rounded-3 shadow-sm" style="background:var(--secondary);color:#fff">
                            <i class="fas fa-shield-alt fa-2x mb-3" style="color:var(--gold)"></i>
                            <h5 class="fw-bold">@L["About_SafetyFirst"]</h5>
                            <p class="mb-0" style="color:rgba(255,255,255,.7);font-size:.9rem">@L["About_SafetyFirst_Desc"]</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-3 shadow-sm h-100" style="background:var(--primary);color:#fff">
                            <i class="fas fa-leaf fa-2x mb-2"></i>
                            <h6 class="fw-bold">@L["About_EcoFriendly"]</h6>
                            <p class="mb-0" style="font-size:.85rem;opacity:.85">@L["About_EcoFriendly_Desc"]</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 rounded-3 shadow-sm h-100" style="background:var(--gold);color:#000">
                            <i class="fas fa-award fa-2x mb-2"></i>
                            <h6 class="fw-bold">@L["About_AwardedService"]</h6>
                            <p class="mb-0" style="font-size:.85rem;opacity:.85">@L["About_AwardedService_Desc"]</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
