@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-octagon display-1 text-danger mb-3"></i>
    <h1 class="display-4 fw-bold">Something went wrong</h1>
    <p class="lead text-muted">An unexpected error occurred. Please try again later.</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg mt-3">
        <i class="bi bi-house me-2"></i>Go Home
    </a>
</div>
