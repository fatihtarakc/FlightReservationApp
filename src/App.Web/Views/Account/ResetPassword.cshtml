@model App.Dtos.AccountDtos.ResetPasswordDto
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock-fill display-4 text-primary"></i>
                    <h2 class="mt-2 fw-bold">Reset Password</h2>
                    <p class="text-muted">Enter the code sent to <strong>@ViewBag.Email</strong></p>
                </div>

                @await Html.PartialAsync("_ValidationSummary")

                <form asp-action="ResetPassword" method="post">
                    <input type="hidden" asp-for="Email" value="@ViewBag.Email" />
                    <div class="mb-3">
                        <label asp-for="Code" class="form-label fw-semibold">Reset Code</label>
                        <input asp-for="Code" class="form-control form-control-lg text-center"
                               placeholder="000000" maxlength="6" style="letter-spacing: 0.5rem;" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                        <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-arrow-repeat me-2"></i>Reset Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
