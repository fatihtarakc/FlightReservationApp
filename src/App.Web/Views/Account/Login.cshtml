@model App.Dtos.AccountDtos.SignInDto
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-person-circle display-4 text-primary"></i>
                    <h2 class="mt-2 fw-bold">Sign In</h2>
                    <p class="text-muted">Welcome back to FlightReservation</p>
                </div>

                @await Html.PartialAsync("_ValidationSummary")

                <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
                    <div class="mb-3">
                        <label asp-for="UsernameOrEmail" class="form-label fw-semibold">Username or Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="UsernameOrEmail" class="form-control" placeholder="johndoe or your@email.com" autocomplete="username" />
                        </div>
                        <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3 text-end">
                        <a asp-action="ForgotPassword" class="text-muted small">Forgot password?</a>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </button>
                </form>

                <hr class="my-4" />
                <p class="text-center mb-0">
                    Don't have an account?
                    <a asp-action="Register" class="text-primary fw-semibold">Register</a>
                </p>
            </div>
        </div>
    </div>
</div>
