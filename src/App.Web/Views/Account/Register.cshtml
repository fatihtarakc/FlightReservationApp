@model App.Dtos.AccountDtos.RegisterDto
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus-fill display-4 text-primary"></i>
                    <h2 class="mt-2 fw-bold">Create Account</h2>
                    <p class="text-muted">Join FlightReservation today</p>
                </div>

                @await Html.PartialAsync("_ValidationSummary")

                <form asp-action="Register" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-semibold">First Name</label>
                            <input asp-for="Name" class="form-control" placeholder="John" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Surname" class="form-label fw-semibold">Last Name</label>
                            <input asp-for="Surname" class="form-control" placeholder="Doe" />
                            <span asp-validation-for="Surname" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label fw-semibold">Username</label>
                            <input asp-for="Username" class="form-control" placeholder="johndoe" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="john@example.com" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+905551234567" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BirthDate" class="form-label fw-semibold">Date of Birth</label>
                            <input asp-for="BirthDate" class="form-control" type="date" />
                            <span asp-validation-for="BirthDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Nationality" class="form-label fw-semibold">Nationality <span class="text-muted">(optional)</span></label>
                            <input asp-for="Nationality" class="form-control" placeholder="Turkish" />
                        </div>
                        <div class="col-12">
                            <label asp-for="PreferredNotificationChannel" class="form-label fw-semibold">Notification Preference</label>
                            <select asp-for="PreferredNotificationChannel" class="form-select">
                                <option value="1">Email</option>
                                <option value="2">SMS</option>
                                <option value="4">WhatsApp</option>
                                <option value="7">All (Email + SMS + WhatsApp)</option>
                            </select>
                        </div>
                        <div class="col-12 mt-2">
                            <button type="submit" class="btn btn-primary w-100 btn-lg">
                                <i class="bi bi-person-check me-2"></i>Create Account
                            </button>
                        </div>
                    </div>
                </form>

                <hr class="my-4" />
                <p class="text-center mb-0">
                    Already have an account?
                    <a asp-action="Login" class="text-primary fw-semibold">Sign In</a>
                </p>
            </div>
        </div>
    </div>
</div>
