@model App.Web.ViewModels.Account.VerifyPhoneVM
@{
    Layout = "_Layout";
}
<div class="min-vh-100 d-flex align-items-center py-5" style="background:linear-gradient(135deg,var(--secondary),#0f3460)">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">
                <div class="card border-0 shadow-lg" style="border-radius:16px">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <i class="fas fa-comment-sms fa-3x text-success mb-3"></i>
                            <h4 class="fw-bold mb-1" style="color:var(--secondary)">@L["Account_VerifySms"]</h4>
                            <p class="text-muted small">@L["Account_VerifySms_Subtitle"]</p>
                            @if (!string.IsNullOrEmpty(Model.MaskedPhone))
                            {
                                <p class="text-muted small fw-semibold">@Model.MaskedPhone</p>
                            }
                        </div>

                        <div id="verifyAlerts"></div>

                        <form asp-action="VerifySms" method="post" id="verifyForm" novalidate>
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Email" value="@Model.Email" />
                            <input type="hidden" name="MaskedPhone" value="@Model.MaskedPhone" />

                            <div class="mb-4">
                                <label asp-for="Code" class="form-label fw-semibold text-muted small text-uppercase">@L["Account_VerificationCode"]</label>
                                <input asp-for="Code" class="form-control text-center fw-bold fs-4"
                                       placeholder="• • • • • •" maxlength="6"
                                       style="letter-spacing:8px" autocomplete="one-time-code" required />
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-success w-100 py-3 fw-bold mb-3">
                                <i class="fas fa-check-circle me-2"></i>@L["Account_VerifySms_Btn"]
                            </button>
                        </form>

                        <hr class="my-3" />

                        <form asp-action="ResendSmsConfirmation" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="email" value="@Model.Email" />
                            <input type="hidden" name="maskedPhone" value="@Model.MaskedPhone" />
                            <button type="submit" class="btn btn-outline-success w-100 py-2 fw-semibold">
                                <i class="fas fa-redo me-2"></i>@L["Account_ResendSmsCode"]
                            </button>
                        </form>

                        <div class="text-center mt-3">
                            <a asp-action="SignIn" class="text-muted small">
                                <i class="fas fa-arrow-left me-1"></i>@L["Account_BackToSignIn"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
(function () {
    'use strict';

    var data = {
        codeSent:      @Json.Serialize(Context.Request.Query["codeSent"] == "True"),
        showWarning:   @Json.Serialize(Context.Request.Query["showWarning"] == "True"),
        email:         @Json.Serialize(Model.Email),
        codeSentMsg:   @Json.Serialize(L["Account_CodeSentToPhone"].Value),
        warningMsg:    @Json.Serialize(L["Account_Email_Has_Not_Confirmed"].Value),
        enterEmailMsg: @Json.Serialize(L["Account_EnterEmailForPhoneVerify"].Value)
    };

    var alertsEl = document.getElementById('verifyAlerts');
    if (alertsEl) {
        var html = '';
        if (data.codeSent) {
            html += '<div class="alert alert-success d-flex align-items-center gap-2 mb-3">'
                  + '<i class="fas fa-paper-plane"></i><span>' + data.codeSentMsg + '</span></div>';
        }
        if (data.showWarning && data.email) {
            html += '<div class="alert alert-warning d-flex align-items-center gap-2 mb-3">'
                  + '<i class="fas fa-exclamation-triangle"></i><span>' + data.warningMsg + '</span></div>';
        }
        if (data.showWarning && !data.email) {
            html += '<div class="alert alert-info d-flex align-items-center gap-2 mb-3">'
                  + '<i class="fas fa-info-circle"></i><span>' + data.enterEmailMsg + '</span></div>';
        }
        alertsEl.innerHTML = html;
    }

    var form = document.getElementById('verifyForm');
    if (!form) return;
    form.addEventListener('submit', function (e) {
        if (!form.checkValidity()) { e.preventDefault(); e.stopPropagation(); }
        form.classList.add('was-validated');
    }, false);
    var codeInput = form.querySelector('[name="Code"]');
    if (codeInput) {
        codeInput.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 6);
        });
    }
})();
</script>
}
