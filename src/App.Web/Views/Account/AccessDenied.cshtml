@{
    Layout = "_Layout";
}
<div class="min-vh-100 d-flex align-items-center justify-content-center text-center py-5">
    <div>
        <div style="font-size:6rem;color:var(--primary)"><i class="fas fa-ban"></i></div>
        <h2 class="fw-bold mt-3" style="color:var(--secondary)">@L["AccessDenied_Title"]</h2>
        <p class="text-muted">@L["AccessDenied_Message"]</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-book mt-3 px-5">@L["Btn_BackHome"]</a>
    </div>
</div>
