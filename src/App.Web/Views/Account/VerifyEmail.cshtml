@model VerifyEmailViewModel
@{
    ViewData["Title"] = "Verify Email";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-body p-4 text-center">
                <i class="bi bi-envelope-check-fill display-4 text-primary mb-3"></i>
                <h2 class="fw-bold">Verify Your Email</h2>
                <p class="text-muted mb-4">
                    A verification code has been sent to <strong>@ViewBag.Email</strong>.
                    Enter it below to activate your account.
                </p>

                @await Html.PartialAsync("_ValidationSummary")

                <form asp-action="VerifyEmail" method="post">
                    <input type="hidden" asp-for="Email" value="@ViewBag.Email" />
                    <div class="mb-3">
                        <label asp-for="Code" class="form-label fw-semibold">Verification Code</label>
                        <input asp-for="Code" class="form-control form-control-lg text-center"
                               placeholder="000000" maxlength="6" style="letter-spacing: 0.5rem; font-size: 1.5rem;" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-check-circle me-2"></i>Verify
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
