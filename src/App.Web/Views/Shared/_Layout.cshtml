@{
    var pubCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var pubAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var computedTitle = (pubCtrl, pubAction) switch {
        ("Home", "About") => L["Nav_About"].Value,
        ("Home", _) => L["Home_Tagline"].Value,
        ("Flight", _) => L["Nav_Flights"].Value,
        ("Account", "SignIn") => L["Account_SignIn"].Value,
        ("Account", "SignUp") => L["Account_SignUp"].Value,
        ("Account", "ForgotPassword") => L["ForgotPassword_Title"].Value,
        ("Account", "ResetPassword") => L["Account_ResetPassword"].Value,
        ("Account", "AccessDenied") => L["AccessDenied_Title"].Value,
        _ => "SkyWay Airlines"
    };
    var pageTitle = ViewData["Title"] is string vdt && !string.IsNullOrEmpty(vdt) ? vdt : computedTitle;
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - SkyWay Airlines</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="pageLoader">
        <div class="loader-brand"><i class="fas fa-plane me-2"></i>Sky<span>Way</span></div>
        <div class="loader-runway">
            <div class="loader-bar"></div>
            <i class="fas fa-plane loader-plane-icon"></i>
        </div>
    </div>

    <div class="navbar-top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-none d-md-block">
                <a href="@L["Footer_PhoneLink"]"><i class="fas fa-phone me-1"></i> @L["Footer_Phone"]</a>
                <a href="mailto:@L["Footer_Email"]"><i class="fas fa-envelope me-1"></i> @L["Footer_Email"]</a>
            </div>
            <div class="d-flex align-items-center ms-auto ms-md-0">
                @if (!string.IsNullOrEmpty(Context.Session.GetString("JwtToken")))
                {
                    <span class="me-3 d-none d-sm-inline"><i class="fas fa-user-circle me-1"></i> @Context.Session.GetString("UserName")</span>
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="me-2">@L["Nav_AdminPanel"]</a>
                    }
                    else
                    {
                        <a asp-area="Passenger" asp-controller="Home" asp-action="Index" class="me-2">@L["Nav_MyAccount"]</a>
                    }
                    <form asp-controller="Account" asp-action="SignOut" asp-area="" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-light">@L["Nav_SignOut"]</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="SignUp" asp-area="" class="me-2">@L["Nav_SignUp"]</a>
                    <button type="button" id="signInPanelBtn" class="btn btn-sm" style="background:var(--gold);color:#000;font-weight:700;">@L["Nav_SignIn"]</button>
                }
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-skyway sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-plane me-2"></i>Sky<span>Way</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon" style="filter:invert(1)"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">@L["Nav_Home"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Flight" asp-action="Index">@L["Nav_Flights"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">@L["Nav_About"]</a>
                    </li>
                </ul>
                <div class="navbar-lang ms-3">
                    @{
                        var currentLang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
                    }
                    <a asp-controller="Home" asp-action="SetLanguage" asp-route-lang="tr-TR" asp-route-returnUrl="@Context.Request.Path"
                       class="lang-btn @(currentLang == "tr" ? "active-lang" : "")">TR</a>
                    <a asp-controller="Home" asp-action="SetLanguage" asp-route-lang="en-US" asp-route-returnUrl="@Context.Request.Path"
                       class="lang-btn @(currentLang == "en" ? "active-lang" : "")">EN</a>
                </div>
                <a asp-area="" asp-controller="Flight" asp-action="Index" class="btn btn-book ms-3">
                    <i class="fas fa-search me-1"></i> @L["Nav_SearchTicket"]
                </a>
            </div>
        </div>
    </nav>

    @await Component.InvokeAsync("Notyf")

    <main>
        @RenderBody()
    </main>

    <footer class="footer-skyway">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h5 class="text-white mb-3"><i class="fas fa-plane me-2 text-primary-color"></i>SkyWay Airlines</h5>
                    <p class="footer-contact-item">@L["Footer_Description"]</p>
                    <div class="mt-3">
                        <a href="#" class="btn btn-sm me-1" style="background:rgba(255,255,255,.1);color:#fff"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-sm me-1" style="background:rgba(255,255,255,.1);color:#fff"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="btn btn-sm me-1" style="background:rgba(255,255,255,.1);color:#fff"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4 mb-4">
                    <h6>@L["Nav_Home"]</h6>
                    <a asp-area="" asp-controller="Home" asp-action="Index">@L["Nav_Home"]</a>
                    <a asp-area="" asp-controller="Flight" asp-action="Index">@L["Nav_Flights"]</a>
                    <a asp-area="" asp-controller="Home" asp-action="About">@L["Nav_About"]</a>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h6>@L["Footer_Services"]</h6>
                    <a href="#">@L["Footer_CheckIn"]</a>
                    <a href="#">@L["Footer_Baggage"]</a>
                    <a href="#">@L["Footer_PassengerGuide"]</a>
                    <a href="#">@L["Footer_FAQ"]</a>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h6>@L["Footer_Contact"]</h6>
                    <p class="footer-contact-item"><i class="fas fa-map-marker-alt me-2 text-primary-color"></i>@L["Footer_Location"]</p>
                    <p class="footer-contact-item"><i class="fas fa-phone me-2 text-primary-color"></i>@L["Footer_Phone"]</p>
                    <p class="footer-contact-item"><i class="fas fa-envelope me-2 text-primary-color"></i>@L["Footer_Email"]</p>
                </div>
            </div>
            <div class="footer-bottom d-flex justify-content-between">
                <span>&copy; 2026 SkyWay Airlines. @L["Footer_Copyright"]</span>
                <span>
                    <a href="#" class="me-3">@L["Footer_Privacy"]</a>
                    <a href="#">@L["Footer_Terms"]</a>
                </span>
            </div>
        </div>
    </footer>

    <div id="signInPanel" class="signin-panel" style="display:none"
         data-error-generic="@L["Error_Generic"]"
         data-redirect-admin="@Url.Action("Index","Home",new{area="Admin"})"
         data-redirect-passenger="@Url.Action("Index","Home",new{area="Passenger"})">
        <div class="signin-panel-header">
            <span class="signin-panel-title"><i class="fas fa-user-circle me-2" style="color:var(--primary)"></i>@L["Nav_SignIn"]</span>
            <button type="button" id="signInPanelClose" class="signin-panel-close" aria-label="close">&times;</button>
        </div>
        <form id="signInPanelForm" novalidate autocomplete="on">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label small fw-bold">@L["Label_UsernameOrEmail"]</label>
                <input type="text" name="UsernameOrEmail" id="siUsername" class="form-control" autocomplete="username" required />
            </div>
            <div class="mb-3">
                <label class="form-label small fw-bold">@L["Label_Password"]</label>
                <input type="password" name="Password" id="siPassword" class="form-control" autocomplete="current-password" required />
            </div>
            <div class="mb-3 d-flex justify-content-between align-items-center">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" name="RememberMe" id="siRememberMe" value="true" />
                    <label class="form-check-label small" for="siRememberMe">@L["Label_RememberMe"]</label>
                </div>
                <a asp-controller="Account" asp-action="ForgotPassword" asp-area="" class="small link-primary-color">@L["SignIn_ForgotPassword"]</a>
            </div>
            <div id="signInPanelError" class="alert alert-danger py-2 small mb-3" style="display:none"></div>
            <button type="submit" id="signInPanelSubmit" class="btn w-100 fw-bold" style="background:var(--gold);color:#000">
                <i class="fas fa-sign-in-alt me-1"></i> @L["Btn_SignIn"]
            </button>
            <div class="text-center mt-3">
                <span class="small text-muted">@L["SignIn_NoAccount"]</span>
                <a asp-controller="Account" asp-action="SignUp" asp-area="" class="small link-primary-color ms-1 fw-bold">@L["Nav_SignUp"]</a>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/signin-panel.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
