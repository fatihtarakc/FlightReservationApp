@model FlightDetailPageVM
@{
    ViewData["Title"] = $"{Model.Flight.FlightNumber} - {L["Flight_SeatSelection"]}";

    // Column groups: soldan sağa, 3'er gruplar halinde (A-B-C | D-E-G | H-J-K vb.)
    var allCols = Model.Seats.Select(s => s.Column).Distinct().OrderBy(c => (int)c).ToList();
    int nc = allCols.Count;
    var colGroups = nc switch {
        <= 2 => new List<List<SeatColumn>> { allCols.ToList() },
        <= 4 => new List<List<SeatColumn>> { allCols.Take(2).ToList(), allCols.Skip(2).ToList() },
        <= 6 => new List<List<SeatColumn>> { allCols.Take(3).ToList(), allCols.Skip(3).ToList() },
        7    => new List<List<SeatColumn>> { allCols.Take(2).ToList(), allCols.Skip(2).Take(3).ToList(), allCols.Skip(5).ToList() },
        <= 9 => new List<List<SeatColumn>> { allCols.Take(3).ToList(), allCols.Skip(3).Take(3).ToList(), allCols.Skip(6).ToList() },
        _    => new List<List<SeatColumn>> { allCols.Take(3).ToList(), allCols.Skip(3).Take(4).ToList(), allCols.Skip(7).ToList() },
    };

    // Hızlı arama: (Row, Column) → SeatVM
    var seatLookup = Model.Seats.ToDictionary(s => (s.Row, s.Column));

    // Sınıf bölümleri (yukarıdan aşağı sırayla)
    var classSections = new (SeatClass Cls, string Label, string Color)[] {
        (SeatClass.First,          L["Flight_First"].Value,          "#e65100"),
        (SeatClass.Business,       L["Flight_Business"].Value,       "#1565c0"),
        (SeatClass.PremiumEconomy, L["Flight_PremiumEconomy"].Value, "#6a1b9a"),
        (SeatClass.Economy,        L["Flight_Economy"].Value,        "#2e7d32"),
    };
}

<section class="py-4" style="background:var(--secondary);color:#fff">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2" style="--bs-breadcrumb-divider-color:rgba(255,255,255,.5)">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" style="color:rgba(255,255,255,.7)">@L["Nav_Home"]</a></li>
                <li class="breadcrumb-item"><a asp-controller="Flight" asp-action="Index" style="color:rgba(255,255,255,.7)">@L["Nav_Flights"]</a></li>
                <li class="breadcrumb-item active text-white">@Model.Flight.FlightNumber</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">@Model.Flight.FlightNumber</h2>
                <span class="text-white-50">@Model.Flight.OriginIata → @Model.Flight.DestinationIata &nbsp;·&nbsp; @Model.Flight.DepartureTime.ToString("dd MMMM yyyy")</span>
            </div>
            <div class="text-end">
                <div class="fw-bold" style="color:var(--gold);font-size:1.4rem">₺@Model.Flight.EconomyPrice.ToString("N0")</div>
                <small style="color:rgba(255,255,255,.7)">@L["Flight_FromEconomy"]</small>
            </div>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container">
        <div class="row g-4">
            <!-- Flight Info -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3 pb-2 border-bottom" style="color:var(--secondary)">@L["Flight_Info"]</h6>
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <div class="text-center">
                                <div class="fw-bold fs-3" style="color:var(--secondary)">@Model.Flight.DepartureTime.ToString("HH:mm")</div>
                                <div class="fw-bold" style="color:var(--primary)">@Model.Flight.OriginIata</div>
                                <small class="text-muted">@Model.Flight.OriginCity</small>
                            </div>
                            <div class="text-center">
                                <small class="text-muted d-block">@Model.Flight.DurationFormatted</small>
                                <i class="fas fa-plane" style="color:var(--primary)"></i>
                            </div>
                            <div class="text-center">
                                <div class="fw-bold fs-3" style="color:var(--secondary)">@Model.Flight.ArrivalTime.ToString("HH:mm")</div>
                                <div class="fw-bold" style="color:var(--primary)">@Model.Flight.DestinationIata</div>
                                <small class="text-muted">@Model.Flight.DestinationCity</small>
                            </div>
                        </div>
                        <table class="table table-sm table-borderless">
                            <tr><td class="text-muted small">@L["Flight_Aircraft"]</td><td class="fw-bold small">@Model.Flight.AircraftModel</td></tr>
                        </table>
                        <div class="mt-3 p-3 rounded" style="background:#f8f9fa">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="small">@L["Flight_Economy"]</span>
                                <strong style="color:var(--primary)">₺@Model.Flight.EconomyPrice.ToString("N0")</strong>
                            </div>
                            @if (Model.Flight.PremiumEconomyPrice.HasValue)
                            {
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small">@L["Flight_PremiumEconomy"]</span>
                                    <strong style="color:var(--primary)">₺@Model.Flight.PremiumEconomyPrice.Value.ToString("N0")</strong>
                                </div>
                            }
                            @if (Model.Flight.BusinessPrice.HasValue)
                            {
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small">@L["Flight_Business"]</span>
                                    <strong style="color:var(--primary)">₺@Model.Flight.BusinessPrice.Value.ToString("N0")</strong>
                                </div>
                            }
                            @if (Model.Flight.FirstClassPrice.HasValue)
                            {
                                <div class="d-flex justify-content-between">
                                    <span class="small">@L["Flight_First"]</span>
                                    <strong style="color:var(--primary)">₺@Model.Flight.FirstClassPrice.Value.ToString("N0")</strong>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3" style="color:var(--secondary)">@L["Seat_Legend"]</h6>
                        <div class="d-flex align-items-center mb-2"><div class="seat-btn seat-available seat-legend-icon me-2"></div><small>@L["Seat_Available"]</small></div>
                        <div class="d-flex align-items-center mb-2"><div class="seat-btn seat-occupied seat-legend-icon me-2"></div><small>@L["Seat_Occupied"]</small></div>
                        <div class="d-flex align-items-center mb-2"><div class="seat-btn seat-selected seat-legend-icon me-2"></div><small>@L["Seat_Selected"]</small></div>
                        <div class="d-flex align-items-center mb-2"><div class="seat-btn seat-premium seat-legend-icon me-2"></div><small>@L["Seat_PremiumEconomy"]</small></div>
                        <div class="d-flex align-items-center mb-2"><div class="seat-btn seat-business seat-legend-icon me-2"></div><small>@L["Seat_Business"]</small></div>
                        <div class="d-flex align-items-center mb-2"><div class="seat-btn seat-first seat-legend-icon me-2"></div><small>@L["Seat_First"]</small></div>
                        <div class="d-flex align-items-center"><div class="seat-btn seat-available seat-legroom seat-legend-icon me-2"></div><small>@L["Seat_ExtraLegroom"]</small></div>
                    </div>
                </div>
            </div>

            <!-- Seat Map -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3 pb-2 border-bottom" style="color:var(--secondary)">
                            <i class="fas fa-chair me-2" style="color:var(--primary)"></i>@L["Flight_SeatSelection"]
                        </h6>

                        @if (!Model.Seats.Any())
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="fas fa-chair fa-3x mb-3"></i>
                                <p>@L["Seat_NotFound"]</p>
                            </div>
                        }
                        else
                        {
                            <div id="seatMapContainer" class="plane-map-wrap">

                                <!-- Uçak burnu -->
                                <div class="plane-nose"></div>

                                <div class="plane-cabin">
                                    <!-- Uçak modeli -->
                                    <div class="text-center mb-2" style="font-size:.65rem;font-weight:700;letter-spacing:1px;color:#6c757d">
                                        @Model.Flight.AircraftModel
                                    </div>

                                    <!-- Kolon başlıkları (A B C | D E G | H J K) -->
                                    <div class="smap-row mb-1">
                                        <div class="smap-row-num"></div>
                                        @for (int gi = 0; gi < colGroups.Count; gi++)
                                        {
                                            <div class="smap-group">
                                                @foreach (var col in colGroups[gi])
                                                {
                                                    <div class="smap-col-lbl">@col</div>
                                                }
                                            </div>
                                            @if (gi < colGroups.Count - 1)
                                            {
                                                <div class="smap-aisle"></div>
                                            }
                                        }
                                    </div>

                                    <!-- Koltuk sınıfı bölümleri -->
                                    @foreach (var seg in classSections)
                                    {
                                        var rows = Model.Seats
                                            .Where(s => s.SeatClass == seg.Cls)
                                            .Select(s => s.Row)
                                            .Distinct()
                                            .OrderBy(r => r)
                                            .ToList();

                                        if (!rows.Any()) { continue; }

                                        <div class="smap-divider" style="color:@seg.Color">@seg.Label</div>

                                        @foreach (var rowNum in rows)
                                        {
                                            <div class="smap-row">
                                                <div class="smap-row-num">@rowNum</div>
                                                @for (int gi = 0; gi < colGroups.Count; gi++)
                                                {
                                                    <div class="smap-group">
                                                        @foreach (var col in colGroups[gi])
                                                        {
                                                            @if (seatLookup.TryGetValue((rowNum, col), out var seat))
                                                            {
                                                                var btnCls = !seat.IsAvailable ? "seat-occupied"
                                                                    : seg.Cls == SeatClass.First          ? "seat-first"
                                                                    : seg.Cls == SeatClass.Business        ? "seat-business"
                                                                    : seg.Cls == SeatClass.PremiumEconomy  ? "seat-premium"
                                                                    : "seat-available";
                                                                if (seat.IsAvailable && seat.HasExtraLegRoom)
                                                                    btnCls += " seat-legroom";
                                                                <button type="button"
                                                                        class="seat-btn @btnCls"
                                                                        data-seat-id="@seat.Id"
                                                                        data-seat-number="@seat.SeatNumber"
                                                                        data-seat-class="@((int)seat.SeatClass)"
                                                                        data-available="@seat.IsAvailable.ToString().ToLower()"
                                                                        @(!seat.IsAvailable ? "disabled" : "")
                                                                        title="@seat.SeatNumber">
                                                                    @col
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <div class="smap-empty"></div>
                                                            }
                                                        }
                                                    </div>
                                                    @if (gi < colGroups.Count - 1)
                                                    {
                                                        <div class="smap-aisle"></div>
                                                    }
                                                }
                                            </div>
                                        }
                                    }
                                </div>

                                <!-- Uçak kuyruğu -->
                                <div class="plane-tail"></div>
                            </div>

                            <div id="selectedSeatInfo" class="mt-3 p-3 rounded d-none" style="background:#f8f9fa;border:2px solid var(--primary)">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@L["Seat_Selected"]: </strong><span id="selectedSeatNumber" class="fw-bold" style="color:var(--primary)"></span>
                                        <span class="ms-2 text-muted" id="selectedSeatClass"></span>
                                    </div>
                                    @if (Model.IsLoggedIn)
                                    {
                                        <button type="button" id="bookNowBtn" class="btn btn-book"
                                                data-please-select="@L["Seat_PleaseSelect"]"
                                                data-booking-url="/Passenger/Booking/Create?flightId=@Model.Flight.Id">
                                            @L["Booking_Proceed"] <i class="fas fa-arrow-right ms-1"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" id="signInBookBtn" class="btn btn-book"
                                                data-flight-id="@Model.Flight.Id"
                                                data-please-select="@L["Seat_PleaseSelect"]">
                                            @L["Nav_SignIn"] &amp; @L["Booking_Proceed"]
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script src="~/js/flight-detail.js" asp-append-version="true"></script>
}
