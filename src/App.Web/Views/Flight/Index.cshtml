@model FlightListPageVM

<section class="py-4" style="background:var(--secondary);color:#fff">
    <div class="container">
        <h2 class="fw-bold mb-0"><i class="fas fa-search me-2" style="color:var(--gold)"></i>@L["Flight_Search"]</h2>
        <p class="mb-0 mt-1" style="color:rgba(255,255,255,.7)">@L["Flight_SearchSubtitle"]</p>
    </div>
</section>

<section class="py-4" style="background:#f8f9fa;border-bottom:1px solid #dee2e6">
    <div class="container">
        @{
            var depCity = Model.Airports.FirstOrDefault(a => a.IataCode == Model.SearchVM.DepartureIata)?.City ?? "";
            var arrCity = Model.Airports.FirstOrDefault(a => a.IataCode == Model.SearchVM.ArrivalIata)?.City ?? "";
        }
        <form asp-action="Index" method="get" id="searchForm">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">@L["Flight_Departure"]</label>
                    <button type="button" id="departurePicker" class="airport-toggle-btn"
                            data-placeholder="@L["Label_SelectOption"]">
                        @if (!string.IsNullOrEmpty(depCity))
                        {
                            <span id="departureText">@depCity</span>
                        }
                        else
                        {
                            <span id="departureText" class="airport-placeholder">@L["Label_SelectOption"]</span>
                        }
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <input type="hidden" name="DepartureIata" id="departureIataInput" value="@Model.SearchVM.DepartureIata">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">@L["Flight_Arrival"]</label>
                    <button type="button" id="arrivalPicker" class="airport-toggle-btn"
                            data-placeholder="@L["Label_SelectOption"]">
                        @if (!string.IsNullOrEmpty(arrCity))
                        {
                            <span id="arrivalText">@arrCity</span>
                        }
                        else
                        {
                            <span id="arrivalText" class="airport-placeholder">@L["Label_SelectOption"]</span>
                        }
                        <i class="fas fa-chevron-down"></i>
                    </button>
                    <input type="hidden" name="ArrivalIata" id="arrivalIataInput" value="@Model.SearchVM.ArrivalIata">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">@L["Flight_Date"]</label>
                    @{ var depDateStr = string.IsNullOrEmpty(Model.SearchVM.DepartureIata) ? DateTime.Today.ToString("yyyy-MM-dd") : Model.SearchVM.DepartureDate.ToString("yyyy-MM-dd"); }
                    <input type="date" name="DepartureDate" value="@depDateStr" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">@L["Label_CabinAndPassenger"]</label>
                    <div id="passengerPicker"
                         data-cabin="@((int)Model.SearchVM.SeatClass)"
                         data-passengers="@Model.SearchVM.Passengers"
                         data-label-passenger="@L["Label_Passenger"]"
                         data-label-economy="@L["Flight_Economy"]"
                         data-label-business="@L["Flight_Business"]">
                        <button type="button" id="passengerToggle" class="pax-toggle-btn">
                            <span id="passengerSummary">@Model.SearchVM.Passengers @L["Label_Passenger"] · @(Model.SearchVM.SeatClass == SeatClass.Business ? L["Flight_Business"] : L["Flight_Economy"])</span>
                            <i class="fas fa-chevron-down"></i>
                        </button>
                        <input type="hidden" name="Passengers" id="passengersInput" value="@Model.SearchVM.Passengers">
                        <input type="hidden" name="SeatClass" id="seatClassInput" value="@((int)Model.SearchVM.SeatClass)">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn w-100 fw-bold" style="background:var(--primary);color:#fff">
                        <i class="fas fa-search me-1"></i> @L["Btn_Search"]
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<section class="py-4">
    <div class="container">
        @if (Model.IsSearchResult)
        {
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0" style="color:var(--secondary)">
                    @Model.SearchVM.DepartureIata &rarr; @Model.SearchVM.ArrivalIata &nbsp;
                    <span class="text-muted fw-normal" style="font-size:.9rem">@Model.SearchVM.DepartureDate.ToString("dd MMMM yyyy")</span>
                </h5>
                <span class="badge" style="background:var(--primary)">@Model.Flights.Count @L["Flight_Found"]</span>
            </div>
        }

        @if (!Model.Flights.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-plane-slash fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">@L["Flight_NotFound"]</h4>
                <p class="text-muted">@L["Flight_TryDifferent"]</p>
                <a asp-action="Index" class="btn btn-book mt-2">@L["Flight_All"]</a>
            </div>
        }
        else
        {
            <div id="flightList">
                @foreach (var flight in Model.Flights)
                {
                    var statusClass = flight.Status switch {
                        FlightStatus.Scheduled => "status-scheduled",
                        FlightStatus.Boarding => "status-boarding",
                        FlightStatus.Departed => "status-departed",
                        FlightStatus.Delayed => "status-delayed",
                        FlightStatus.Cancelled => "status-cancelled",
                        FlightStatus.Arrived => "status-arrived",
                        _ => "status-scheduled"
                    };
                    <div class="flight-card mb-3">
                        <div class="row align-items-center">
                            <div class="col-md-2 text-center border-end">
                                <div class="fw-bold" style="color:var(--primary)">@flight.FlightNumber</div>
                                <small class="text-muted">@flight.AircraftModel</small>
                            </div>
                            <div class="col-md-5">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="text-center">
                                        <div class="fw-bold fs-4">@flight.DepartureTime.ToString("HH:mm")</div>
                                        <div class="fw-bold" style="color:var(--primary)">@flight.OriginIata</div>
                                        <small class="text-muted">@flight.OriginCity</small>
                                        <div class="text-muted" style="font-size:.75rem">@flight.DepartureTime.ToString("dd MMM")</div>
                                    </div>
                                    <div class="text-center px-3">
                                        <small class="text-muted">@flight.DurationFormatted</small>
                                        <div class="d-flex align-items-center">
                                            <div style="height:2px;width:50px;background:#dee2e6"></div>
                                            <i class="fas fa-plane mx-1 text-muted" style="font-size:.7rem"></i>
                                            <div style="height:2px;width:50px;background:#dee2e6"></div>
                                        </div>
                                        <span class="status-badge @statusClass">@L["Status_" + flight.Status.ToString()]</span>
                                    </div>
                                    <div class="text-center">
                                        <div class="fw-bold fs-4">@flight.ArrivalTime.ToString("HH:mm")</div>
                                        <div class="fw-bold" style="color:var(--primary)">@flight.DestinationIata</div>
                                        <small class="text-muted">@flight.DestinationCity</small>
                                        <div class="text-muted" style="font-size:.75rem">@flight.ArrivalTime.ToString("dd MMM")</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 border-start">
                                <div class="px-3">
                                    <div class="mb-1">
                                        <small class="text-muted">Economy</small>
                                        <span class="float-end fw-bold" style="color:var(--primary)">₺@flight.EconomyPrice.ToString("N0")</span>
                                    </div>
                                    @if (flight.BusinessPrice.HasValue)
                                    {
                                        <div class="mb-1">
                                            <small class="text-muted">Business</small>
                                            <span class="float-end fw-bold" style="color:var(--primary)">₺@flight.BusinessPrice.Value.ToString("N0")</span>
                                        </div>
                                    }
                                    <div class="d-flex gap-1 mt-2" style="font-size:.75rem">
                                        <span class="text-muted"><i class="fas fa-chair me-1"></i>@flight.AvailableEconomySeats Eco</span>
                                        <span class="text-muted ms-2"><i class="fas fa-chair me-1"></i>@flight.AvailableBusinessSeats Biz</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2 text-center">
                                <a asp-controller="Flight" asp-action="Detail" asp-route-id="@flight.Id"
                                   class="btn fw-bold d-block" style="background:var(--primary);color:#fff;border-radius:8px">
                                    @L["Btn_SelectSeat"]
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<div id="passengerPanel" class="pax-panel" style="display:none">
    <div class="pax-cabin-row">
        <div class="pax-cabin-opt @(Model.SearchVM.SeatClass == SeatClass.Business ? "" : "active")" data-cabin="1">@L["Flight_Economy"]</div>
        <div class="pax-cabin-opt @(Model.SearchVM.SeatClass == SeatClass.Business ? "active" : "")" data-cabin="3">@L["Flight_Business"]</div>
    </div>
    <div class="pax-row-item">
        <div class="pax-label"><strong>@L["Flight_Passengers"]</strong></div>
        <div class="pax-counter">
            <button type="button" class="pax-btn" id="paxMinus">−</button>
            <span class="pax-num" id="passengerCount">@Model.SearchVM.Passengers</span>
            <button type="button" class="pax-btn" id="paxPlus">+</button>
        </div>
    </div>
    <button type="button" id="passengerConfirm" class="pax-confirm-btn">@L["Btn_Ok"]</button>
</div>

<div id="airportPanel" class="airport-panel" style="display:none">
    <div class="airport-panel-header">
        <button type="button" id="airportPanelClose" class="airport-panel-close" aria-label="close">&times;</button>
    </div>
    <div class="airport-panel-body">
        <div id="countryList" class="country-list"></div>
        <div id="airportList" class="airport-list"></div>
    </div>
</div>

@section Scripts {
<script src="~/js/airport-picker.js" asp-append-version="true"></script>
<script src="~/js/home-search.js" asp-append-version="true"></script>
}
