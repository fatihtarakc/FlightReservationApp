@model App.Dtos.FlightDtos.FlightDto
@{
    ViewData["Title"] = $"Flight {Model.Number}";
}

<div class="mb-3">
    <a asp-action="Search" class="text-muted">
        <i class="bi bi-arrow-left me-1"></i>Back to Search
    </a>
</div>

<div class="card shadow border-0 mb-4">
    <div class="card-header bg-primary text-white p-3">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0 fw-bold">@Model.AirlineName — Flight @Model.Number</h4>
                <small class="opacity-75">@Model.ModelName · @Model.AircraftTailNumber</small>
            </div>
            <span class="badge bg-light text-dark fs-6">
                @Model.FlightStatus
            </span>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="row align-items-center mb-4">
            <div class="col-md-4 text-center">
                <div class="display-6 fw-bold">@Model.DepartureDateTime.ToString("HH:mm")</div>
                <div class="fs-5 text-primary fw-semibold">@Model.DepartureAirportIata</div>
                <div class="text-muted">@Model.DepartureCity</div>
                <div class="text-muted small">@Model.DepartureDateTime.ToString("dd MMM yyyy")</div>
                @if (!string.IsNullOrEmpty(Model.Terminal))
                {
                    <div class="badge bg-secondary mt-1">Terminal @Model.Terminal</div>
                }
                @if (!string.IsNullOrEmpty(Model.Gate))
                {
                    <div class="badge bg-info mt-1">Gate @Model.Gate</div>
                }
            </div>
            <div class="col-md-4 text-center">
                <div class="text-muted small mb-1">@Model.Duration.ToString(@"h\h\ mm\m")</div>
                <div class="d-flex align-items-center">
                    <div class="border-top flex-grow-1"></div>
                    <i class="bi bi-airplane-fill text-primary mx-3 fs-4"></i>
                    <div class="border-top flex-grow-1"></div>
                </div>
                <div class="text-muted small mt-1">Direct Flight</div>
            </div>
            <div class="col-md-4 text-center">
                <div class="display-6 fw-bold">@Model.ArrivalDateTime.ToString("HH:mm")</div>
                <div class="fs-5 text-primary fw-semibold">@Model.ArrivalAirportIata</div>
                <div class="text-muted">@Model.ArrivalCity</div>
                <div class="text-muted small">@Model.ArrivalDateTime.ToString("dd MMM yyyy")</div>
            </div>
        </div>

        <hr />

        <h5 class="fw-semibold mb-3">Pricing & Availability</h5>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="card border text-center p-3">
                    <div class="fw-semibold text-muted mb-1">Economy</div>
                    <div class="fs-4 fw-bold text-success">@Model.BaseEconomyPrice.ToString("N0")</div>
                    <div class="text-muted small">@Model.Currency</div>
                    <div class="badge bg-light text-dark mt-1">@Model.AvailableEconomySeats seats</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border text-center p-3">
                    <div class="fw-semibold text-muted mb-1">Premium Economy</div>
                    <div class="fs-4 fw-bold text-success">@Model.BasePremiumEconomyPrice.ToString("N0")</div>
                    <div class="text-muted small">@Model.Currency</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border text-center p-3">
                    <div class="fw-semibold text-muted mb-1">Business</div>
                    <div class="fs-4 fw-bold text-success">@Model.BaseBusinessPrice.ToString("N0")</div>
                    <div class="text-muted small">@Model.Currency</div>
                    <div class="badge bg-light text-dark mt-1">@Model.AvailableBusinessSeats seats</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border text-center p-3">
                    <div class="fw-semibold text-muted mb-1">First Class</div>
                    <div class="fs-4 fw-bold text-success">@Model.BaseFirstClassPrice.ToString("N0")</div>
                    <div class="text-muted small">@Model.Currency</div>
                    <div class="badge bg-light text-dark mt-1">@Model.AvailableFirstClassSeats seats</div>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <a asp-action="Book" asp-route-flightId="@Model.Id" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-ticket-perforated me-2"></i>Book This Flight
            </a>
        </div>
    </div>
</div>
