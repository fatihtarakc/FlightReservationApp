@model BookFlightViewModel
@{
    ViewData["Title"] = $"Select Seat — {Model.Flight.Number}";

    var isWideBody = Model.BodyType == BodyType.WideBody;
    var leftCols  = new[] { SeatColumn.A, SeatColumn.B, SeatColumn.C };
    var midCols   = isWideBody ? new[] { SeatColumn.D, SeatColumn.E } : Array.Empty<SeatColumn>();
    var rightCols = isWideBody
        ? new[] { SeatColumn.F, SeatColumn.G, SeatColumn.H, SeatColumn.J, SeatColumn.K }
        : new[] { SeatColumn.D, SeatColumn.E, SeatColumn.F };

    var allCols = leftCols.Concat(midCols).Concat(rightCols).ToArray();

    static string ClassColor(SeatClass sc) => sc switch
    {
        SeatClass.First          => "first-class",
        SeatClass.Business       => "business-class",
        SeatClass.PremiumEconomy => "premium-class",
        _                        => "economy-class"
    };

    static string ClassBadge(SeatClass sc) => sc switch
    {
        SeatClass.First          => "badge bg-warning text-dark",
        SeatClass.Business       => "badge bg-primary",
        SeatClass.PremiumEconomy => "badge bg-info text-dark",
        _                        => "badge bg-secondary"
    };
}

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const radios = document.querySelectorAll('input[name="selectedSeatId"]');
    const confirmBtn = document.getElementById('confirmBtn');
    const selectedInfo = document.getElementById('selectedInfo');

    radios.forEach(r => {
        r.addEventListener('change', function () {
            const lbl = document.querySelector('label[for="' + this.id + '"]');
            selectedInfo.textContent = 'Selected: ' + lbl.dataset.seat + ' (' + lbl.dataset.cls + ')';
            confirmBtn.disabled = false;
        });
    });
});
</script>
}

<style>
.seat-map-wrapper { font-size: 0.78rem; }
.cabin-zone { border-radius: 12px; padding: 1rem; margin-bottom: 1.25rem; }
.cabin-zone.first-class     { background: linear-gradient(135deg, #fff8e1 0%, #ffe082 100%); border: 1px solid #ffd54f; }
.cabin-zone.business-class  { background: linear-gradient(135deg, #e3f2fd 0%, #90caf9 100%); border: 1px solid #64b5f6; }
.cabin-zone.premium-class   { background: linear-gradient(135deg, #e0f7fa 0%, #80deea 100%); border: 1px solid #4dd0e1; }
.cabin-zone.economy-class   { background: linear-gradient(135deg, #f3f3f3 0%, #e0e0e0 100%); border: 1px solid #bdbdbd; }
.seat-row { display: flex; align-items: center; gap: 3px; margin-bottom: 4px; }
.row-num { width: 22px; text-align: right; font-weight: 600; color: #666; margin-right: 4px; flex-shrink: 0; }
.aisle-gap { width: 20px; flex-shrink: 0; }
.seat-btn-wrap input[type=radio] { position: absolute; opacity: 0; width: 0; height: 0; }
.seat-btn-wrap label {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: 6px 6px 3px 3px;
    font-size: 0.68rem; font-weight: 700; cursor: pointer;
    border: 2px solid transparent; transition: all .15s; user-select: none;
}
.seat-available.first-class-seat   label { background: #ffd54f; border-color: #f9a825; color: #5d4037; }
.seat-available.business-class-seat label { background: #64b5f6; border-color: #1976d2; color: #0d47a1; }
.seat-available.premium-class-seat label { background: #4dd0e1; border-color: #0097a7; color: #006064; }
.seat-available.economy-class-seat  label { background: #e0e0e0; border-color: #9e9e9e; color: #424242; }
.seat-available label:hover { transform: scale(1.12); box-shadow: 0 2px 8px rgba(0,0,0,.25); }
.seat-btn-wrap input[type=radio]:checked + label { border-color: #1565c0 !important; box-shadow: 0 0 0 3px rgba(21,101,192,.4); transform: scale(1.12); }
.seat-occupied label { background: #ccc !important; border-color: #bbb !important; color: #888 !important; cursor: not-allowed; }
.col-header { width: 34px; text-align: center; font-weight: 700; color: #555; font-size: 0.7rem; }
.col-header-row { display: flex; align-items: center; gap: 3px; margin-bottom: 6px; }
.window-dot { width: 5px; height: 5px; border-radius: 50%; background: #1976d2; margin-left: 2px; }
.aisle-bar { width: 3px; height: 100%; background: rgba(0,0,0,.1); border-radius: 2px; }
.cabin-title { font-weight: 800; letter-spacing: .5px; text-transform: uppercase; font-size: .8rem; margin-bottom: .5rem; }
</style>

<div class="mb-3">
    <a asp-action="Details" asp-route-id="@Model.Flight.Id" class="text-muted">
        <i class="bi bi-arrow-left me-1"></i>Back to Flight Details
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0"><i class="bi bi-airplane-fill me-2"></i>Seat Map — @Model.Flight.Number</h5>
                    <small class="opacity-75">@Model.Flight.AirlineName · @Model.Flight.ModelName · @(isWideBody ? "Wide Body" : "Narrow Body")</small>
                </div>
                <span class="badge bg-secondary">@Model.AllSeats.Count(s => s.IsAvailable) seats available</span>
            </div>
            <div class="card-body p-3">

                @if (!Model.AllSeats.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-x-circle display-4 text-danger"></i>
                        <h5 class="mt-3">No seats available for this flight.</h5>
                    </div>
                }
                else
                {
                    <form asp-action="Book" asp-route-flightId="@Model.Flight.Id" method="post">

                        <div class="seat-map-wrapper">
                        @{
                            var classes = new[] { SeatClass.First, SeatClass.Business, SeatClass.PremiumEconomy, SeatClass.Economy };
                        }
                        @foreach (var cabin in classes)
                        {
                            var cabinSeats = Model.AllSeats.Where(s => s.SeatClass == cabin).ToList();
                            if (!cabinSeats.Any()) continue;

                            var rows = cabinSeats.Select(s => s.Row).Distinct().OrderBy(r => r).ToList();
                            var seatDict = cabinSeats.ToDictionary(s => (s.Row, s.Column));
                            var zoneClass = ClassColor(cabin);

                            <div class="cabin-zone @zoneClass">
                                <div class="d-flex align-items-center mb-2 gap-2">
                                    <span class="cabin-title">@cabin</span>
                                    <span class="@ClassBadge(cabin)">@cabinSeats.Count(s => s.IsAvailable) available</span>
                                </div>

                                <div class="col-header-row">
                                    <div style="width:26px"></div>
                                    @foreach (var col in leftCols)
                                    {
                                        <div class="col-header">@col</div>
                                    }
                                    <div class="aisle-gap"></div>
                                    @foreach (var col in midCols)
                                    {
                                        <div class="col-header">@col</div>
                                    }
                                    @if (midCols.Any())
                                    {
                                        <div class="aisle-gap"></div>
                                    }
                                    @foreach (var col in rightCols)
                                    {
                                        <div class="col-header">@col</div>
                                    }
                                </div>

                                @foreach (var row in rows)
                                {
                                    <div class="seat-row">
                                        <div class="row-num">@row</div>

                                        @foreach (var col in leftCols)
                                        {
                                            if (seatDict.TryGetValue((row, col), out var seat))
                                            {
                                                var seatCss = $"seat-btn-wrap {(seat.IsAvailable ? $"seat-available {ClassColor(cabin)}-seat" : "seat-occupied")}";
                                                var tooltip = $"{seat.SeatLabel}{(seat.IsWindowSeat ? " · Window" : "")}{(seat.IsAisleSeat ? " · Aisle" : "")}{(seat.HasExtraLegRoom ? " · Extra Legroom" : "")}";
                                                <div class="@seatCss">
                                                    <input type="radio" name="selectedSeatId" id="s_@seat.Id" value="@seat.Id"
                                                           @(seat.IsAvailable ? "" : "disabled") />
                                                    <label for="s_@seat.Id" data-seat="@seat.SeatLabel" data-cls="@cabin" title="@tooltip">
                                                        @seat.SeatLabel
                                                        @if (seat.IsWindowSeat){ <span class="window-dot"></span> }
                                                    </label>
                                                </div>
                                            }
                                            else
                                            {
                                                <div style="width:34px"></div>
                                            }
                                        }

                                        <div class="aisle-gap d-flex align-items-center justify-content-center">
                                            <div class="aisle-bar" style="height:34px"></div>
                                        </div>

                                        @foreach (var col in midCols)
                                        {
                                            if (seatDict.TryGetValue((row, col), out var seat))
                                            {
                                                var seatCss = $"seat-btn-wrap {(seat.IsAvailable ? $"seat-available {ClassColor(cabin)}-seat" : "seat-occupied")}";
                                                <div class="@seatCss">
                                                    <input type="radio" name="selectedSeatId" id="s_@seat.Id" value="@seat.Id"
                                                           @(seat.IsAvailable ? "" : "disabled") />
                                                    <label for="s_@seat.Id" data-seat="@seat.SeatLabel" data-cls="@cabin" title="@seat.SeatLabel">
                                                        @seat.SeatLabel
                                                    </label>
                                                </div>
                                            }
                                            else
                                            {
                                                <div style="width:34px"></div>
                                            }
                                        }

                                        @if (midCols.Any())
                                        {
                                            <div class="aisle-gap d-flex align-items-center justify-content-center">
                                                <div class="aisle-bar" style="height:34px"></div>
                                            </div>
                                        }

                                        @foreach (var col in rightCols)
                                        {
                                            if (seatDict.TryGetValue((row, col), out var seat))
                                            {
                                                var seatCss = $"seat-btn-wrap {(seat.IsAvailable ? $"seat-available {ClassColor(cabin)}-seat" : "seat-occupied")}";
                                                var tooltip = $"{seat.SeatLabel}{(seat.IsWindowSeat ? " · Window" : "")}{(seat.IsAisleSeat ? " · Aisle" : "")}{(seat.HasExtraLegRoom ? " · Extra Legroom" : "")}";
                                                <div class="@seatCss">
                                                    <input type="radio" name="selectedSeatId" id="s_@seat.Id" value="@seat.Id"
                                                           @(seat.IsAvailable ? "" : "disabled") />
                                                    <label for="s_@seat.Id" data-seat="@seat.SeatLabel" data-cls="@cabin" title="@tooltip">
                                                        @seat.SeatLabel
                                                        @if (seat.IsWindowSeat){ <span class="window-dot"></span> }
                                                    </label>
                                                </div>
                                            }
                                            else
                                            {
                                                <div style="width:34px"></div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                        </div>

                        <div class="d-flex flex-wrap gap-3 my-3 px-1">
                            <span class="small"><span class="badge" style="background:#ffd54f;color:#5d4037">First</span> First Class</span>
                            <span class="small"><span class="badge bg-primary">Biz</span> Business</span>
                            <span class="small"><span class="badge bg-info text-dark">Prem</span> Premium Economy</span>
                            <span class="small"><span class="badge bg-secondary">Eco</span> Economy</span>
                            <span class="small"><span class="badge" style="background:#ccc;color:#888">XX</span> Occupied</span>
                            <span class="small"><span class="window-dot d-inline-block" style="width:8px;height:8px;background:#1976d2;border-radius:50%"></span> Window</span>
                        </div>

                        <div class="alert alert-primary py-2 small mb-3" id="selectedInfo">
                            Please select a seat to continue
                        </div>

                        <button type="submit" id="confirmBtn" class="btn btn-success btn-lg w-100 fw-semibold" disabled>
                            <i class="bi bi-check-circle me-2"></i>Confirm Booking — No Payment Required
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow border-0 sticky-top" style="top: 1rem;">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Flight Summary</h5>
            </div>
            <div class="card-body p-3">
                <div class="mb-2">
                    <span class="text-muted small d-block">Airline</span>
                    <span class="fw-semibold">@Model.Flight.AirlineName (@Model.Flight.AirlineIata)</span>
                </div>
                <div class="mb-2">
                    <span class="text-muted small d-block">Flight</span>
                    <span class="fw-bold text-primary">@Model.Flight.Number</span>
                </div>
                <div class="mb-2">
                    <span class="text-muted small d-block">Route</span>
                    <span class="fw-semibold">
                        @Model.Flight.DepartureCity <span class="text-muted">(@Model.Flight.DepartureAirportIata)</span>
                        <i class="bi bi-arrow-right mx-1 text-muted"></i>
                        @Model.Flight.ArrivalCity <span class="text-muted">(@Model.Flight.ArrivalAirportIata)</span>
                    </span>
                </div>
                <div class="mb-2">
                    <span class="text-muted small d-block">Departure</span>
                    <span class="fw-semibold">@Model.Flight.DepartureDateTime.ToString("dd MMM yyyy HH:mm")</span>
                </div>
                <div class="mb-2">
                    <span class="text-muted small d-block">Arrival</span>
                    <span class="fw-semibold">@Model.Flight.ArrivalDateTime.ToString("dd MMM yyyy HH:mm")</span>
                </div>
                <hr />
                <div class="mb-1">
                    <span class="text-muted small d-block">Economy from</span>
                    <span class="fw-bold fs-5 text-success">@Model.Flight.BaseEconomyPrice.ToString("N0") @Model.Flight.Currency</span>
                </div>
                <div class="mb-1">
                    <span class="text-muted small d-block">Business from</span>
                    <span class="fw-semibold text-success">@Model.Flight.BaseBusinessPrice.ToString("N0") @Model.Flight.Currency</span>
                </div>
                <div class="mb-2">
                    <span class="text-muted small d-block">First Class from</span>
                    <span class="fw-semibold text-success">@Model.Flight.BaseFirstClassPrice.ToString("N0") @Model.Flight.Currency</span>
                </div>
                <div class="alert alert-success p-2 small mt-2 mb-0">
                    <i class="bi bi-shield-check me-1"></i>
                    Instant booking confirmation — no payment required.
                </div>
            </div>
        </div>
    </div>
</div>
