@model List<BookingListDto>
@{
    ViewData["Title"] = "My Bookings";
}

<h2 class="fw-bold mb-4">
    <i class="bi bi-ticket-perforated me-2 text-primary"></i>My Bookings
</h2>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-ticket-perforated display-1 text-muted"></i>
        <h4 class="mt-3 text-muted">No bookings yet.</h4>
        <a asp-controller="Flight" asp-action="Search" class="btn btn-primary mt-3">
            <i class="bi bi-search me-2"></i>Search Flights
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var booking in Model)
        {
            var statusClass = booking.BookingStatus switch
            {
                BookingStatus.Confirmed => "success",
                BookingStatus.Cancelled => "danger",
                BookingStatus.CheckedIn => "info",
                _ => "secondary"
            };

            <div class="col-12">
                <div class="card shadow-sm border-0 booking-card">
                    <div class="card-body p-3">
                        <div class="row align-items-center">
                            <div class="col-md-2">
                                <div class="text-muted small">PNR</div>
                                <div class="fw-bold fs-5 font-monospace text-primary">@booking.PnrNumber</div>
                                <span class="badge bg-@statusClass">@booking.BookingStatus</span>
                            </div>
                            <div class="col-md-4">
                                <div class="text-muted small">Flight</div>
                                <div class="fw-semibold">@booking.FlightNumber</div>
                                <div class="d-flex align-items-center mt-1">
                                    <span class="fw-bold">@booking.DepartureCity</span>
                                    <i class="bi bi-arrow-right mx-2 text-muted"></i>
                                    <span class="fw-bold">@booking.ArrivalCity</span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="text-muted small">Departure</div>
                                <div class="fw-semibold">@booking.DepartureDateTime.ToString("dd MMM yyyy")</div>
                                <div class="text-muted small">@booking.DepartureDateTime.ToString("HH:mm")</div>
                            </div>
                            <div class="col-md-2">
                                <div class="text-muted small">Seat</div>
                                <div class="fw-semibold">@booking.SeatNumber</div>
                                <div class="badge bg-light text-dark border">@booking.SeatClass</div>
                            </div>
                            <div class="col-md-1 text-center">
                                <div class="text-muted small">Price</div>
                                <div class="fw-bold text-success">@booking.TotalPrice.ToString("N0")</div>
                            </div>
                            <div class="col-md-1 text-end">
                                <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
