@model FlightReservation.Web.ViewModels.Flight.FlightSearchResultsViewModel
@{
    ViewData["Title"] = "Uçuş Ara";
}

<div class="card mb-4 p-3">
    <form asp-controller="Flight" asp-action="Search" method="post">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold"><i class="fas fa-plane-departure me-1 text-primary"></i>Kalkış</label>
                <select name="Origin" class="form-select" required>
                    <option value="">Seçiniz...</option>
                    @foreach (var r in Model.Search.Routes.GroupBy(x => x.OriginCode))
                    {
                        var first = r.First();
                        var originSel = Model.Search.Origin == first.OriginCode;
                        <option value="@first.OriginCode" selected="@originSel">
                            @first.OriginCity (@first.OriginCode)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold"><i class="fas fa-plane-arrival me-1 text-primary"></i>Varış</label>
                <select name="Destination" class="form-select" required>
                    <option value="">Seçiniz...</option>
                    @foreach (var r in Model.Search.Routes.GroupBy(x => x.DestinationCode))
                    {
                        var first = r.First();
                        var destSel = Model.Search.Destination == first.DestinationCode;
                        <option value="@first.DestinationCode" selected="@destSel">
                            @first.DestinationCity (@first.DestinationCode)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold"><i class="fas fa-calendar me-1 text-primary"></i>Tarih</label>
                <input type="date" name="Date" class="form-control"
                       value="@Model.Search.Date.ToString("yyyy-MM-dd")"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 fw-semibold">
                    <i class="fas fa-search me-2"></i>Ara
                </button>
            </div>
        </div>
    </form>
</div>

@if (!string.IsNullOrEmpty(Model.Search.Origin))
{
    <h5 class="mb-3 text-muted">
        @Model.Search.Origin → @Model.Search.Destination &nbsp;|&nbsp;
        @Model.Search.Date.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
        &nbsp;|&nbsp; <strong>@Model.Flights.Count sefer bulundu</strong>
    </h5>

    @if (!Model.Flights.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-plane fa-3x text-muted mb-3"></i>
            <h5 class="text-muted">Bu tarih ve güzergahta sefer bulunamadı.</h5>
        </div>
    }
    else
    {
        foreach (var flight in Model.Flights)
        {
            <div class="card mb-3 hover-shadow">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-5">
                            <div class="d-flex align-items-center gap-4">
                                <div class="text-center">
                                    <div class="fs-4 fw-bold">@flight.DepartureUtc.ToLocalTime().ToString("HH:mm")</div>
                                    <div class="text-muted small">@flight.OriginCode</div>
                                    <div class="text-muted small">@flight.OriginCity</div>
                                </div>
                                <div class="text-center flex-grow-1">
                                    <div class="text-muted small">@flight.Duration.Hours s @flight.Duration.Minutes dk</div>
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1" style="border-top: 2px solid #dee2e6;"></div>
                                        <i class="fas fa-plane mx-2 text-primary"></i>
                                        <div class="flex-grow-1" style="border-top: 2px solid #dee2e6;"></div>
                                    </div>
                                    <div class="text-muted small">@flight.FlightNumber</div>
                                </div>
                                <div class="text-center">
                                    <div class="fs-4 fw-bold">@flight.ArrivalUtc.ToLocalTime().ToString("HH:mm")</div>
                                    <div class="text-muted small">@flight.DestinationCode</div>
                                    <div class="text-muted small">@flight.DestinationCity</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="text-muted small"><i class="fas fa-plane me-1"></i>@flight.AircraftModel</div>
                            @if (flight.Gate != null)
                            {
                                <div class="text-muted small"><i class="fas fa-door-open me-1"></i>Kapı @flight.Gate — Terminal @flight.Terminal</div>
                            }
                        </div>
                        <div class="col-md-2 text-center">
                            <div class="fw-bold @(flight.AvailableSeats < 10 ? "text-danger" : "text-success")">
                                @flight.AvailableSeats koltuk
                            </div>
                            <div class="text-muted small">müsait</div>
                        </div>
                        <div class="col-md-2 text-end">
                            <a asp-controller="Flight" asp-action="Details"
                               asp-route-id="@flight.Id"
                               asp-route-origin="@flight.SearchOrigin"
                               asp-route-destination="@flight.SearchDestination"
                               asp-route-date="@flight.SearchDate.ToString("yyyy-MM-dd")"
                               class="btn btn-primary">
                                Koltuk Seç
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}
