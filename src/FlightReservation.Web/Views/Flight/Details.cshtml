@model FlightReservation.Web.ViewModels.Flight.FlightDetailsViewModel
@{
    ViewData["Title"] = $"Sefer {Model.FlightNumber}";
    var columns = Model.SeatsPerRow == 9
        ? new[] { "A", "B", "C", "D", "E", "F", "G", "H", "J" }
        : new[] { "A", "B", "C", "D", "E", "F" };
    var aisleAfter = Model.SeatsPerRow == 9 ? 3 : 3;
}

<div class="mb-3">
    <a asp-controller="Flight" asp-action="Search"
       asp-route-origin="@ViewBag.ReturnOrigin"
       asp-route-destination="@ViewBag.ReturnDestination"
       asp-route-date="@ViewBag.ReturnDate"
       class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i>Sonuçlara Dön
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h4 class="fw-bold mb-1">
                    <i class="fas fa-plane me-2 text-primary"></i>@Model.FlightNumber
                </h4>
                <div class="d-flex align-items-center gap-4 mt-3">
                    <div class="text-center">
                        <div class="fs-3 fw-bold">@Model.DepartureUtc.ToLocalTime().ToString("HH:mm")</div>
                        <div class="fs-5 text-primary">@Model.OriginCode</div>
                        <div class="text-muted">@Model.OriginCity</div>
                    </div>
                    <div class="text-center flex-grow-1">
                        <div class="text-muted small">@((Model.ArrivalUtc - Model.DepartureUtc).Hours)s @((Model.ArrivalUtc - Model.DepartureUtc).Minutes)dk</div>
                        <div style="border-top: 2px dashed #adb5bd;"></div>
                    </div>
                    <div class="text-center">
                        <div class="fs-3 fw-bold">@Model.ArrivalUtc.ToLocalTime().ToString("HH:mm")</div>
                        <div class="fs-5 text-primary">@Model.DestinationCode</div>
                        <div class="text-muted">@Model.DestinationCity</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small mb-1"><i class="fas fa-calendar me-1"></i>@Model.DepartureUtc.ToLocalTime().ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</div>
                <div class="text-muted small mb-1"><i class="fas fa-plane me-1"></i>@Model.AircraftModel</div>
                @if (Model.Gate != null)
                {
                    <div class="text-muted small"><i class="fas fa-door-open me-1"></i>Kapı @Model.Gate — Terminal @Model.Terminal</div>
                }
            </div>
            <div class="col-md-3 text-end">
                <div class="mb-2">
                    <span class="badge bg-success fs-6 me-1">Economy: @Model.AvailableEconomy</span>
                </div>
                <div>
                    <span class="badge bg-primary fs-6">Business: @Model.AvailableBusiness</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title mb-4"><i class="fas fa-chair me-2"></i>Koltuk Haritası</h5>

        <div class="d-flex gap-4 mb-4 flex-wrap">
            <span><span class="badge bg-success me-1">&nbsp;&nbsp;</span>Boş (Economy)</span>
            <span><span class="badge bg-primary me-1">&nbsp;&nbsp;</span>Boş (Business)</span>
            <span><span class="badge bg-secondary me-1">&nbsp;&nbsp;</span>Dolu</span>
            <span><span class="badge bg-warning me-1">&nbsp;&nbsp;</span>Çıkış Sırası</span>
        </div>

        <div class="table-responsive">
            <table class="table table-borderless text-center" style="width: auto; margin: 0 auto;">
                <thead>
                    <tr>
                        <th class="text-muted small" style="width:40px">Sıra</th>
                        @for (int ci = 0; ci < columns.Length; ci++)
                        {
                            if (ci == aisleAfter)
                            {
                                <th style="width:24px"></th>
                            }
                            <th class="text-muted small" style="width:40px">@columns[ci]</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int row = 1; row <= Model.TotalRows; row++)
                    {
                        <tr>
                            <td class="text-muted small align-middle">@row</td>
                            @for (int ci = 0; ci < columns.Length; ci++)
                            {
                                if (ci == aisleAfter)
                                {
                                    <td style="width:24px"></td>
                                }
                                var col = columns[ci];
                                var seat = Model.Seats.FirstOrDefault(s => s.RowNumber == row && s.ColumnLetter == col);
                                if (seat == null)
                                {
                                    <td></td>
                                }
                                else if (seat.IsOccupied)
                                {
                                    <td>
                                        <button class="btn btn-sm btn-secondary p-1" style="width:36px;height:34px;font-size:10px;" disabled title="Dolu">
                                            @seat.SeatNumber
                                        </button>
                                    </td>
                                }
                                else
                                {
                                    var btnClass = seat.IsExitRow ? "btn-warning" : (seat.SeatClass == FlightReservation.Core.Enums.SeatClass.Business ? "btn-primary" : "btn-success");
                                    <td>
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            <a asp-controller="Reservation" asp-action="Create"
                                               asp-route-flightId="@Model.Id"
                                               asp-route-seatId="@seat.Id"
                                               class="btn btn-sm @btnClass p-1" style="width:36px;height:34px;font-size:10px;"
                                               title="@seat.SeatNumber - @(seat.SeatClass == FlightReservation.Core.Enums.SeatClass.Business ? "Business" : "Economy")@(seat.IsExitRow ? " (Çıkış)" : "")">
                                                @seat.SeatNumber
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Account" asp-action="Login"
                                               asp-route-returnUrl="@Context.Request.Path"
                                               class="btn btn-sm @btnClass p-1" style="width:36px;height:34px;font-size:10px;"
                                               title="Giriş yapın">
                                                @seat.SeatNumber
                                            </a>
                                        }
                                    </td>
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
