@model FlightReservation.Web.ViewModels.Reservation.CancelReservationViewModel
@{
    ViewData["Title"] = "Rezervasyon İptal";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-semibold">
                <i class="fas fa-exclamation-triangle me-2"></i>Rezervasyonu İptal Et
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <strong>@Model.PnrCode</strong> — @Model.FlightNumber (@Model.Route)<br />
                    <span class="small">Kalkış: @Model.DepartureUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("tr-TR"))</span>
                </div>

                <form asp-action="Cancel" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="PnrCode" />
                    <input type="hidden" asp-for="FlightNumber" />
                    <input type="hidden" asp-for="Route" />
                    <input type="hidden" asp-for="DepartureUtc" />

                    <div class="mb-4">
                        <label asp-for="Reason" class="form-label"></label>
                        <textarea asp-for="Reason" class="form-control" rows="3" placeholder="İptal nedeninizi belirtiniz..."></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger fw-semibold">
                            <i class="fas fa-times me-2"></i>İptal Et
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Vazgeç</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
