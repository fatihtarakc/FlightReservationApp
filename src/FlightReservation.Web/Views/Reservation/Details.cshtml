@model FlightReservation.Web.ViewModels.Reservation.ReservationViewModel
@{
    ViewData["Title"] = $"Rezervasyon {Model.PnrCode}";
    var statusColor = Model.Status switch
    {
        FlightReservation.Core.Enums.ReservationStatus.Active => "success",
        FlightReservation.Core.Enums.ReservationStatus.Cancelled => "danger",
        FlightReservation.Core.Enums.ReservationStatus.CheckedIn => "info",
        _ => "secondary"
    };
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="text-center mb-4">
            <div class="fs-1 fw-bold text-primary font-monospace">@Model.PnrCode</div>
            <span class="badge bg-@statusColor fs-6 px-3 py-2">@Model.Status</span>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-semibold bg-primary text-white">
                <i class="fas fa-plane me-2"></i>Sefer Bilgileri
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4 text-center">
                        <div class="fs-3 fw-bold">@Model.DepartureUtc.ToLocalTime().ToString("HH:mm")</div>
                        <div class="text-muted">@Model.Route.Split('→')[0].Trim()</div>
                        <div class="text-muted small">@Model.DepartureUtc.ToLocalTime().ToString("dd MMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</div>
                    </div>
                    <div class="col-md-4 text-center d-flex flex-column justify-content-center">
                        <i class="fas fa-plane fa-2x text-primary"></i>
                        <div class="text-muted small mt-1">@Model.FlightNumber</div>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="fs-3 fw-bold">@Model.ArrivalUtc.ToLocalTime().ToString("HH:mm")</div>
                        <div class="text-muted">@Model.Route.Split('→')[1].Trim()</div>
                        <div class="text-muted small">@Model.ArrivalUtc.ToLocalTime().ToString("dd MMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</div>
                    </div>
                </div>
                @if (Model.Gate != null)
                {
                    <div class="text-center mt-3 text-muted small">
                        <i class="fas fa-door-open me-1"></i>Kapı @Model.Gate — Terminal @Model.Terminal
                    </div>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-semibold">
                <i class="fas fa-user me-2"></i>Yolcu & Koltuk
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="text-muted small">Yolcu Adı</div>
                        <div class="fw-semibold">@Model.PassengerFullName</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small">T.C. Kimlik No</div>
                        <div class="fw-semibold">@Model.PassengerIdentityNumber</div>
                    </div>
                    <div class="col-md-6 mt-3">
                        <div class="text-muted small">Koltuk</div>
                        <div class="fw-semibold">@Model.SeatNumber
                            <span class="badge @(Model.SeatClass == FlightReservation.Core.Enums.SeatClass.Business ? "bg-primary" : "bg-success") ms-1">
                                @(Model.SeatClass == FlightReservation.Core.Enums.SeatClass.Business ? "Business" : "Economy")
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6 mt-3">
                        <div class="text-muted small">Rezervasyon Tarihi</div>
                        <div class="fw-semibold">@Model.ReservedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("tr-TR"))</div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Status == FlightReservation.Core.Enums.ReservationStatus.Cancelled && Model.CancelReason != null)
        {
            <div class="alert alert-danger">
                <strong>İptal Nedeni:</strong> @Model.CancelReason
                <br /><small>@Model.CancelledAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("tr-TR"))</small>
            </div>
        }

        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Rezervasyonlarım
            </a>
            @if (Model.Status == FlightReservation.Core.Enums.ReservationStatus.Active && Model.DepartureUtc > DateTime.UtcNow)
            {
                <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                    <i class="fas fa-times me-1"></i>İptal Et
                </a>
            }
        </div>
    </div>
</div>
