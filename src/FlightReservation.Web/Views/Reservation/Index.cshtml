@model IEnumerable<FlightReservation.Web.ViewModels.Reservation.ReservationViewModel>
@{
    ViewData["Title"] = "Rezervasyonlarım";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0"><i class="fas fa-ticket-alt me-2 text-primary"></i>Rezervasyonlarım</h3>
    <a asp-controller="Flight" asp-action="Search" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Yeni Rezervasyon
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-ticket-alt fa-4x text-muted mb-3"></i>
        <h5 class="text-muted">Henüz rezervasyonunuz bulunmuyor.</h5>
        <a asp-controller="Flight" asp-action="Search" class="btn btn-primary mt-3">
            <i class="fas fa-search me-2"></i>Uçuş Ara
        </a>
    </div>
}
else
{
    foreach (var r in Model)
    {
        var statusColor = r.Status switch
        {
            FlightReservation.Core.Enums.ReservationStatus.Active => "success",
            FlightReservation.Core.Enums.ReservationStatus.Cancelled => "danger",
            FlightReservation.Core.Enums.ReservationStatus.CheckedIn => "info",
            _ => "secondary"
        };
        <div class="card mb-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-2 text-center">
                        <div class="fs-4 fw-bold text-primary font-monospace">@r.PnrCode</div>
                        <span class="badge bg-@statusColor">@r.Status</span>
                    </div>
                    <div class="col-md-4">
                        <div class="fw-semibold">@r.FlightNumber — @r.Route</div>
                        <div class="text-muted small">
                            <i class="fas fa-calendar me-1"></i>@r.DepartureUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("tr-TR"))
                        </div>
                        <div class="text-muted small">
                            <i class="fas fa-chair me-1"></i>@r.SeatNumber
                            (@(r.SeatClass == FlightReservation.Core.Enums.SeatClass.Business ? "Business" : "Economy"))
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small"><i class="fas fa-user me-1"></i>@r.PassengerFullName</div>
                        @if (r.Gate != null)
                        {
                            <div class="text-muted small"><i class="fas fa-door-open me-1"></i>Kapı @r.Gate — @r.Terminal</div>
                        }
                        <div class="text-muted small">
                            <i class="fas fa-clock me-1"></i>@r.ReservedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm", new System.Globalization.CultureInfo("tr-TR"))
                        </div>
                    </div>
                    <div class="col-md-3 text-end">
                        <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary me-1">
                            <i class="fas fa-eye me-1"></i>Detay
                        </a>
                        @if (r.Status == FlightReservation.Core.Enums.ReservationStatus.Active && r.DepartureUtc > DateTime.UtcNow)
                        {
                            <a asp-action="Cancel" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-times me-1"></i>İptal
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}
