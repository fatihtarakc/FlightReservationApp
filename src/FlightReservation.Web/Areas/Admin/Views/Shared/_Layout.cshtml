<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root { --sidebar: #1a3c6e; --accent: #2563a8; }
        body { background: #f0f2f5; }
        .sidebar { width: 240px; min-height: 100vh; background: var(--sidebar); position: fixed; top: 0; left: 0; z-index: 100; }
        .sidebar .brand { padding: 1.25rem 1.5rem; font-size: 1.1rem; font-weight: 700; color: #fff; border-bottom: 1px solid rgba(255,255,255,.1); }
        .sidebar .nav-link { color: rgba(255,255,255,.75); padding: .6rem 1.5rem; border-radius: 0; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,.1); }
        .sidebar .nav-section { color: rgba(255,255,255,.4); font-size: .75rem; padding: .75rem 1.5rem .25rem; text-transform: uppercase; letter-spacing: .05em; }
        .main-content { margin-left: 240px; padding: 1.5rem; }
        .topbar { background: #fff; border-bottom: 1px solid #dee2e6; padding: .75rem 1.5rem; margin: -1.5rem -1.5rem 1.5rem; display: flex; justify-content: space-between; align-items: center; }
        .card { border: none; box-shadow: 0 2px 6px rgba(0,0,0,.07); border-radius: 10px; }
        .stat-card { border-left: 4px solid; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="sidebar">
        <div class="brand"><i class="fas fa-plane me-2"></i>Admin Panel</div>
        <nav class="nav flex-column mt-2">
            <div class="nav-section">Genel</div>
            <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="fas fa-tachometer-alt me-2"></i>Dashboard
            </a>
            <div class="nav-section mt-2">Yönetim</div>
            <a class="nav-link" asp-area="Admin" asp-controller="Flight" asp-action="Index">
                <i class="fas fa-plane me-2"></i>Seferler
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Route" asp-action="Index">
                <i class="fas fa-route me-2"></i>Güzergahlar
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="Aircraft" asp-action="Index">
                <i class="fas fa-fighter-jet me-2"></i>Uçaklar
            </a>
            <a class="nav-link" asp-area="Admin" asp-controller="User" asp-action="Index">
                <i class="fas fa-users me-2"></i>Kullanıcılar
            </a>
            <div class="nav-section mt-2">Sistem</div>
            <a class="nav-link" href="/hangfire" target="_blank">
                <i class="fas fa-cogs me-2"></i>Hangfire Jobs
            </a>
            <div class="nav-section mt-2"></div>
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-globe me-2"></i>Siteye Git
            </a>
        </nav>
    </div>

    <div class="main-content">
        <div class="topbar">
            <h6 class="mb-0 fw-semibold text-muted">@ViewData["Title"]</h6>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small"><i class="fas fa-user me-1"></i>@User.Identity?.Name</span>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="fas fa-sign-out-alt me-1"></i>Çıkış
                    </button>
                </form>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
