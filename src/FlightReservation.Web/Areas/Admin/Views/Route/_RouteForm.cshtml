@model FlightReservation.Web.ViewModels.Admin.RouteFormViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="OriginCity" class="form-label"></label>
        <input asp-for="OriginCity" class="form-control" placeholder="İstanbul" />
        <span asp-validation-for="OriginCity" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="OriginCode" class="form-label"></label>
        <input asp-for="OriginCode" class="form-control" placeholder="IST" maxlength="3" style="text-transform:uppercase" />
        <span asp-validation-for="OriginCode" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DestinationCity" class="form-label"></label>
        <input asp-for="DestinationCity" class="form-control" placeholder="Ankara" />
        <span asp-validation-for="DestinationCity" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DestinationCode" class="form-label"></label>
        <input asp-for="DestinationCode" class="form-control" placeholder="ESB" maxlength="3" style="text-transform:uppercase" />
        <span asp-validation-for="DestinationCode" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DistanceKm" class="form-label"></label>
        <input asp-for="DistanceKm" class="form-control" type="number" />
        <span asp-validation-for="DistanceKm" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="EstimatedDurationMinutes" class="form-label"></label>
        <input asp-for="EstimatedDurationMinutes" class="form-control" type="number" />
        <span asp-validation-for="EstimatedDurationMinutes" class="text-danger small"></span>
    </div>
    <div class="col-12">
        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <label asp-for="IsActive" class="form-check-label">Aktif</label>
        </div>
    </div>
</div>
