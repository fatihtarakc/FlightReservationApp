@model IEnumerable<FlightReservation.Core.Entities.Route>
@{
    ViewData["Title"] = "Güzergahlar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0">Güzergah Listesi</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Yeni Güzergah</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Kalkış</th>
                    <th>Varış</th>
                    <th>Mesafe</th>
                    <th>Süre</th>
                    <th>Durum</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td><strong>@r.OriginCode</strong> <span class="text-muted small">@r.OriginCity</span></td>
                        <td><strong>@r.DestinationCode</strong> <span class="text-muted small">@r.DestinationCity</span></td>
                        <td>@r.DistanceKm km</td>
                        <td>@r.EstimatedDurationMinutes dk</td>
                        <td><span class="badge @(r.IsActive ? "bg-success" : "bg-secondary")">@(r.IsActive ? "Aktif" : "Pasif")</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu güzergahı silmek istediğinizden emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
