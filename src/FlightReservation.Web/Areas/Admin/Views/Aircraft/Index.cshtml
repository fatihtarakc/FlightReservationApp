@model IEnumerable<FlightReservation.Core.Entities.Aircraft>
@{
    ViewData["Title"] = "Uçaklar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0">Uçak Filosu</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Yeni Uçak</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Model</th>
                    <th>Üretici</th>
                    <th>Tescil No</th>
                    <th>Kapasite</th>
                    <th>Business</th>
                    <th>Economy</th>
                    <th>Durum</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="fw-semibold">@a.Model</td>
                        <td>@a.Manufacturer</td>
                        <td class="font-monospace">@a.RegistrationNumber</td>
                        <td>@a.TotalCapacity</td>
                        <td>@a.BusinessCapacity</td>
                        <td>@a.EconomyCapacity</td>
                        <td><span class="badge @(a.IsActive ? "bg-success" : "bg-secondary")">@(a.IsActive ? "Aktif" : "Pasif")</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu uçağı silmek istediğinizden emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
