@model FlightReservation.Web.ViewModels.Admin.AircraftFormViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Model" class="form-label"></label>
        <input asp-for="Model" class="form-control" placeholder="Boeing 737-800" />
        <span asp-validation-for="Model" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Manufacturer" class="form-label"></label>
        <input asp-for="Manufacturer" class="form-control" placeholder="Boeing" />
        <span asp-validation-for="Manufacturer" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="RegistrationNumber" class="form-label"></label>
        <input asp-for="RegistrationNumber" class="form-control" placeholder="TC-JHM" />
        <span asp-validation-for="RegistrationNumber" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="TotalRows" class="form-label"></label>
        <input asp-for="TotalRows" class="form-control" type="number" />
        <span asp-validation-for="TotalRows" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="SeatsPerRow" class="form-label"></label>
        <input asp-for="SeatsPerRow" class="form-control" type="number" />
        <span asp-validation-for="SeatsPerRow" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="BusinessRowCount" class="form-label"></label>
        <input asp-for="BusinessRowCount" class="form-control" type="number" />
        <span asp-validation-for="BusinessRowCount" class="text-danger small"></span>
    </div>
    <div class="col-12">
        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <label asp-for="IsActive" class="form-check-label">Aktif</label>
        </div>
    </div>
</div>
