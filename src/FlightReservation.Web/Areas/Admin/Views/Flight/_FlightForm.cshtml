@model FlightReservation.Web.ViewModels.Admin.FlightFormViewModel

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="FlightNumber" class="form-label"></label>
        <input asp-for="FlightNumber" class="form-control" placeholder="TK1001" />
        <span asp-validation-for="FlightNumber" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<FlightReservation.Core.Enums.FlightStatus>()"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="RouteId" class="form-label"></label>
        <select asp-for="RouteId" class="form-select" asp-items="Model.Routes">
            <option value="">Güzergah seçiniz...</option>
        </select>
        <span asp-validation-for="RouteId" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="AircraftId" class="form-label"></label>
        <select asp-for="AircraftId" class="form-select" asp-items="Model.Aircrafts">
            <option value="">Uçak seçiniz...</option>
        </select>
        <span asp-validation-for="AircraftId" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DepartureUtc" class="form-label"></label>
        <input asp-for="DepartureUtc" class="form-control" type="datetime-local" />
        <span asp-validation-for="DepartureUtc" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="ArrivalUtc" class="form-label"></label>
        <input asp-for="ArrivalUtc" class="form-control" type="datetime-local" />
        <span asp-validation-for="ArrivalUtc" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Gate" class="form-label"></label>
        <input asp-for="Gate" class="form-control" placeholder="G1" />
    </div>
    <div class="col-md-6">
        <label asp-for="Terminal" class="form-label"></label>
        <input asp-for="Terminal" class="form-control" placeholder="T1" />
    </div>
</div>
