@model IEnumerable<FlightReservation.Core.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Kullanıcılar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0">Kullanıcı Listesi</h5>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Kayıt Tarihi</th>
                    <th>Durum</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="fw-semibold">@u.FullName</td>
                        <td>@u.Email</td>
                        <td class="small text-muted">@u.CreatedAt.ToLocalTime().ToString("dd MMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td><span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">@(u.IsActive ? "Aktif" : "Pasif")</span></td>
                        <td>
                            <form asp-action="ToggleActive" asp-route-id="@u.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                    @(u.IsActive ? "Devre Dışı" : "Aktif Et")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
