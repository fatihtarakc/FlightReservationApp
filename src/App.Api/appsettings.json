{
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
                "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
                "Hangfire": "Information",
                "MassTransit": "Information",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/flight-reservation-.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 30,
                    "fileSizeLimitBytes": 10485760,
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
                }
            }
        ],
        "Enrich": [ "FromLogContext" ]
    },
    "AllowedHosts": "*",
    "Connections": {
        "MssqlServer": "Server=localhost,1434;Database=FlightReservationDb;User Id=sa;Password=Dockermssqldb2024+-!?;TrustServerCertificate=True;MultipleActiveResultSets=True",
        "PostgreSql": "Host=localhost;Port=5433;Database=FlightReservationDb;Username=postgres;Password=Dockerpostgresqldb2024+-!?",
        "Hangfire": "Host=localhost;Port=5433;Database=FlightReservationDb;Username=postgres;Password=Dockerpostgresqldb2024+-!?",
        "Redis": "localhost:6380,user=admin,password=Dockerredisdb2024+-!?",
        "DatabaseProvider": "PostgreSql"
    },
    "RabbitMqConfiguration": {
        "Host": "localhost",
        "Port": 5672,
        "VirtualHost": "FlightReservationApp",
        "Username": "FlightReservationApp-admin",
        "Password": "Dockerrabbitmq2025+-!?"
    },
    "TokenConfiguration": {
        "Audience": "FlightReservationAudience",
        "Issuer": "FlightReservationIssuer",
        "IssuerSigningSymmetricSecurityKey": "FlightReservation_SuperSecret_JWT_Key_2026!@#$%^&*()",
        "Expiration": 60
    },
    "EmailConfiguration": {
        "From": "FlightReservationApp",
        "EmailFrom": "*********",
        "SmtpServer": "smtp.gmail.com",
